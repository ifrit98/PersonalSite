---
const publications = [
  {
    title: 'Music Style Transformer',
    desc: "St. George, J., Bischof, H.P. — ICAI '19, pp. 22–33. Bayesian-factorized approach to raw-audio transcription, composition, and style transfer.",
    href: '/papers/music-style-transformer.pdf',
  },
  {
    title: 'Sonification of Simulated Black Hole Merger Data',
    desc: "St. George, J., Bischof, H.P., Kim, S.Y. — MSV '18, pp. 3–9. Velocity-modulated synthesis and HRTF spatialization of CCRG merger simulations.",
    href: '/papers/black-hole-sonification.pdf',
  },
];
---

<section class="pub-mini fade-up">
  <div class="container">
    <h2 class="pub-mini__heading">Publications</h2>
    <div class="pub-mini__list">
      {publications.map((pub) => (
        <a href={pub.href} class="pub-mini__item">
          <h3 class="pub-mini__title">{pub.title}</h3>
          <p class="pub-mini__desc">{pub.desc}</p>
        </a>
      ))}
    </div>
  </div>
</section>

<style>
  .pub-mini {
    padding-block: var(--sp-16);
  }

  .pub-mini__heading {
    font: var(--text-h2);
    font-family: var(--font-serif);
    font-weight: 500;
    margin-bottom: var(--sp-6);
  }

  .pub-mini__list {
    display: flex;
    flex-direction: column;
    gap: var(--sp-4);
  }

  .pub-mini__item {
    display: block;
    padding: var(--sp-4);
    border: 1px solid rgba(16, 24, 38, 0.08);
    border-radius: var(--radius-card);
    background-color: var(--color-card-elevated);
    box-shadow: var(--shadow-card-rest);
    text-decoration: none;
    transition:
      border-color var(--duration-normal) var(--ease-out),
      box-shadow var(--duration-normal) var(--ease-out),
      transform var(--duration-normal) var(--ease-out);
  }

  .pub-mini__item:hover {
    border-color: var(--color-brass);
    box-shadow: var(--shadow-card-lift);
    transform: translateY(-2px);
  }

  .pub-mini__title {
    font-family: var(--font-serif);
    font-size: 1.125rem;
    font-weight: 500;
    color: var(--color-ink);
    margin-bottom: var(--sp-1);
  }

  .pub-mini__desc {
    font: var(--text-meta);
    font-family: var(--font-sans);
    color: var(--color-slate);
  }
</style>
