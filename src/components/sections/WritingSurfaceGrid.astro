---
import Button from '@/components/ui/Button.astro';

import { AFTERFIAT_URL, ESCHATOLOGY_URL } from '@/lib/site';
---

<section class="writing-surfaces fade-up">
  <div class="container">
    <h2 class="writing-surfaces__section-heading">Writing Properties</h2>

    <article class="writing-surfaces__capsule">
      <div class="writing-surfaces__capsule-header">
        <span class="writing-surfaces__eyebrow">Thesis / Blueprint</span>
        <h3 class="writing-surfaces__title">AfterFiat — Next-Gen Store of Value: Privacy, Proofs, Compute</h3>
      </div>
      <p class="writing-surfaces__body">
        A versioned, book-length thesis arguing that three cryptographic capacities — privacy-preserving
        settlement, portable proofs, and verified compute — can function as monetary primitives for a
        dense digital civilization. The argument begins from the failure of soft guarantees (central banks,
        broadcast media, credentialed authority) and builds a seven-layer architecture from verifiable
        machines and energy up through communications, identity, proof systems, settlement, and governance.
      </p>
      <div class="writing-surfaces__proof-row">
        <div class="writing-surfaces__proof-item">
          <span class="writing-surfaces__proof-label">Scope</span>
          <span class="writing-surfaces__proof-value">31 chapters + 7 appendices</span>
        </div>
        <div class="writing-surfaces__proof-item">
          <span class="writing-surfaces__proof-label">Key idea</span>
          <span class="writing-surfaces__proof-value">Verification asymmetry as economic hinge</span>
        </div>
        <div class="writing-surfaces__proof-item">
          <span class="writing-surfaces__proof-label">Format</span>
          <span class="writing-surfaces__proof-value">Versioned web edition + downloadable PDF</span>
        </div>
      </div>
      <details class="writing-surfaces__contributions">
        <summary class="writing-surfaces__contributions-toggle">Core contributions</summary>
        <ul class="writing-surfaces__contributions-list">
          <li>Threat model assuming financial repression, censorship, and hardware capture — not benevolence</li>
          <li>VerifyPrice as the public KPI that turns proofs into commodities rather than platform IOUs</li>
          <li>Four reference applications: private treasury, media provenance, verified inference, proof procurement</li>
          <li>"No dashboards, no trust" governance posture with protocol changes driven by SLOs and public receipts</li>
        </ul>
      </details>
      <div class="writing-surfaces__actions">
        <Button href={AFTERFIAT_URL}>Read AfterFiat &rarr;</Button>
        <Button href={`${AFTERFIAT_URL}/v/1.0/read/part-i/0-introduction`} variant="secondary">Start at the Introduction</Button>
      </div>
    </article>

    <article class="writing-surfaces__capsule">
      <div class="writing-surfaces__capsule-header">
        <span class="writing-surfaces__eyebrow">Publication / Essay Series</span>
        <h3 class="writing-surfaces__title">Eschatology Report</h3>
      </div>
      <p class="writing-surfaces__body">
        A publication and members' salon for people trying to think clearly in an age of AI, verification
        collapse, institutional drift, and symbolic overload. Long-form essays, research dossiers, and
        conversations for recovering coherence without false certainty. AfterFiat is a flagship research
        track within the larger publication.
      </p>
      <div class="writing-surfaces__proof-row">
        <div class="writing-surfaces__proof-item">
          <span class="writing-surfaces__proof-label">Platform</span>
          <span class="writing-surfaces__proof-value">Substack — free + member tiers</span>
        </div>
        <div class="writing-surfaces__proof-item">
          <span class="writing-surfaces__proof-label">Voice</span>
          <span class="writing-surfaces__proof-value">Lucid, serious, philosophically literate</span>
        </div>
        <div class="writing-surfaces__proof-item">
          <span class="writing-surfaces__proof-label">Relationship</span>
          <span class="writing-surfaces__proof-value">AfterFiat is a flagship dossier within ER</span>
        </div>
      </div>
      <details class="writing-surfaces__contributions">
        <summary class="writing-surfaces__contributions-toggle">Editorial pillars</summary>
        <ul class="writing-surfaces__contributions-list">
          <li><strong>Existential orientation</strong> — agency, dignity, the self under civilizational pressure</li>
          <li><strong>Epistemic breakdown</strong> — AI, synthetic media, verification collapse, mediated reality</li>
          <li><strong>Civilizational analysis</strong> — technology, finance, governance, infrastructure, fragility</li>
          <li><strong>Living practice</strong> — how to think, build, orient, and act without false certainty</li>
        </ul>
      </details>
      <div class="writing-surfaces__actions">
        <Button href={ESCHATOLOGY_URL}>Visit Eschatology Report &rarr;</Button>
        <Button href="/contact" variant="secondary">Subscribe</Button>
      </div>
    </article>
  </div>
</section>

<style>
  .writing-surfaces {
    padding-block: var(--sp-16);
  }

  .writing-surfaces__section-heading {
    font: var(--text-h2);
    font-family: var(--font-serif);
    font-weight: 500;
    margin-bottom: var(--sp-8);
  }

  .writing-surfaces__capsule {
    padding: var(--sp-8);
    border: 1px solid rgba(16, 24, 38, 0.08);
    border-radius: var(--radius-card);
    background-color: var(--color-card-elevated);
    box-shadow: var(--shadow-card-rest);
    margin-bottom: var(--sp-6);
    transition:
      box-shadow var(--duration-normal) var(--ease-out);
  }

  .writing-surfaces__capsule:hover {
    box-shadow: var(--shadow-card-lift);
  }

  .writing-surfaces__capsule:last-of-type {
    margin-bottom: 0;
  }

  .writing-surfaces__capsule-header {
    margin-bottom: var(--sp-4);
  }

  .writing-surfaces__eyebrow {
    display: block;
    font: var(--text-mono-meta);
    font-family: var(--font-mono);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--color-brass);
    margin-bottom: var(--sp-2);
  }

  .writing-surfaces__title {
    font: var(--text-h3);
    font-family: var(--font-serif);
    font-weight: 500;
  }

  .writing-surfaces__body {
    font: var(--text-body);
    font-family: var(--font-sans);
    color: var(--color-slate);
    max-width: 48em;
    margin-bottom: var(--sp-6);
    line-height: 1.7;
  }

  .writing-surfaces__proof-row {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--sp-4);
    margin-bottom: var(--sp-6);
    padding: var(--sp-4);
    background-color: var(--color-warm-wash);
    border-radius: var(--radius-button);
  }

  .writing-surfaces__proof-item {
    display: flex;
    flex-direction: column;
    gap: var(--sp-1);
  }

  .writing-surfaces__proof-label {
    font: var(--text-mono-meta);
    font-family: var(--font-mono);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--color-brass);
    font-size: 0.6875rem;
  }

  .writing-surfaces__proof-value {
    font: var(--text-meta);
    font-family: var(--font-sans);
    color: var(--color-ink);
  }

  .writing-surfaces__contributions {
    margin-bottom: var(--sp-6);
  }

  .writing-surfaces__contributions-toggle {
    font: var(--text-meta);
    font-family: var(--font-sans);
    font-weight: 500;
    color: var(--color-ink);
    cursor: pointer;
    padding: var(--sp-2) 0;
    transition: color var(--duration-fast) var(--ease-out);
  }

  .writing-surfaces__contributions-toggle:hover {
    color: var(--color-brass);
  }

  .writing-surfaces__contributions-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: var(--sp-2);
    margin-top: var(--sp-3);
  }

  .writing-surfaces__contributions-list li {
    font: var(--text-meta);
    font-family: var(--font-sans);
    color: var(--color-slate);
    padding-left: var(--sp-4);
    border-left: 2px solid var(--color-brass);
    line-height: 1.6;
  }

  .writing-surfaces__contributions-list strong {
    color: var(--color-ink);
    font-weight: 500;
  }

  .writing-surfaces__actions {
    display: flex;
    gap: var(--sp-4);
    flex-wrap: wrap;
  }

  @media (max-width: 768px) {
    .writing-surfaces__proof-row {
      grid-template-columns: 1fr;
    }
  }
</style>
