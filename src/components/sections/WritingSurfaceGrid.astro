---
import Button from '@/components/ui/Button.astro';

import { AFTERFIAT_URL, ESCHATOLOGY_URL } from '@/lib/site';

const surfaces = [
  {
    title: 'AfterFiat',
    body: 'A book-length thesis on verification, repression, synthetic media, and the infrastructure required for credible truth and value in the AI era.',
    cta: 'Read AfterFiat',
    href: AFTERFIAT_URL,
  },
  {
    title: 'Eschatology Report',
    body: 'Long-form writing on AI acceleration, symbolic overload, civilizational drift, and the search for workable orientation.',
    cta: 'Visit Eschatology Report',
    href: ESCHATOLOGY_URL,
  },
];
---

<section class="writing-surfaces fade-up">
  <div class="container">
    <div class="writing-surfaces__grid">
      {surfaces.map((s) => (
        <article class="writing-surfaces__card">
          <h3 class="writing-surfaces__title">{s.title}</h3>
          <p class="writing-surfaces__body">{s.body}</p>
          <Button href={s.href} variant="text">{s.cta} &rarr;</Button>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .writing-surfaces {
    padding-block: var(--sp-16);
  }

  .writing-surfaces__grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--sp-6);
  }

  .writing-surfaces__card {
    padding: var(--sp-6);
    border: 1px solid rgba(16, 24, 38, 0.08);
    border-radius: var(--radius-card);
    background-color: var(--color-card-elevated);
    box-shadow: var(--shadow-card-rest);
    display: flex;
    flex-direction: column;
    transition:
      box-shadow var(--duration-normal) var(--ease-out),
      transform var(--duration-normal) var(--ease-out);
  }

  .writing-surfaces__card:hover {
    box-shadow: var(--shadow-card-lift);
    transform: translateY(-2px);
  }

  .writing-surfaces__title {
    font: var(--text-h3);
    font-family: var(--font-serif);
    font-weight: 500;
    margin-bottom: var(--sp-3);
  }

  .writing-surfaces__body {
    font: var(--text-body);
    font-family: var(--font-sans);
    color: var(--color-slate);
    margin-bottom: var(--sp-4);
    flex: 1;
  }

  @media (max-width: 768px) {
    .writing-surfaces__grid {
      grid-template-columns: 1fr;
    }
  }
</style>
