---
import { ENDORSED_PROPERTIES } from '@/lib/site';
import Eyebrow from '@/components/ui/Eyebrow.astro';
---

<section class="associated fade-up">
  <div class="container">
    <Eyebrow>Associated Work</Eyebrow>
    <p class="associated__intro">
      This site is the canonical layer for my engineering, research, and writing.
      The <strong>flagship properties</strong> are AfterFiat (thesis), Eschatology Report (publication),
      and GAMUT (research). Capability Commons is the public knowledge platform.
      AlchemicalAI is the applied commercial product for real estate workflow automation.
    </p>
    <p class="associated__hierarchy-note">Flagship</p>
    <div class="associated__grid">
      {ENDORSED_PROPERTIES.filter((_, i) => i < 4).map((prop) => (
        <a href={prop.url} class:list={['associated__card', { 'associated__card--has-image': 'image' in prop }]}>
          {'image' in prop && (
            <img src={(prop as any).image} alt="" class="associated__icon" loading="lazy" />
          )}
          <span class="associated__name">{prop.name}</span>
          <span class="associated__tagline">{prop.tagline}</span>
        </a>
      ))}
    </div>
    {ENDORSED_PROPERTIES.length > 4 && (
      <>
        <p class="associated__hierarchy-note associated__hierarchy-note--secondary">Architecture & Applied</p>
        <div class="associated__grid associated__grid--secondary">
          {ENDORSED_PROPERTIES.filter((_, i) => i >= 4).map((prop) => prop.url ? (
            <a href={prop.url} class="associated__card associated__card--secondary">
              <span class="associated__name">{prop.name}</span>
              <span class="associated__tagline">{prop.tagline}</span>
            </a>
          ) : (
            <div class="associated__card associated__card--secondary">
              <span class="associated__name">{prop.name}</span>
              <span class="associated__tagline">{prop.tagline}</span>
            </div>
          ))}
        </div>
      </>
    )}
  </div>
</section>

<style>
  .associated {
    padding-block: var(--sp-16);
    border-top: 1px solid var(--color-line);
  }

  .associated__intro {
    font: var(--text-body);
    font-family: var(--font-sans);
    color: var(--color-slate);
    margin-top: var(--sp-4);
    margin-bottom: var(--sp-8);
    max-width: 42em;
  }

  .associated__intro strong {
    color: var(--color-ink);
  }

  .associated__grid {
    display: flex;
    gap: var(--sp-6);
    flex-wrap: wrap;
  }

  .associated__card {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: var(--sp-6) var(--sp-8);
    border: 1px solid rgba(16, 24, 38, 0.08);
    border-radius: var(--radius-card);
    background-color: var(--color-card-elevated);
    box-shadow: var(--shadow-card-rest);
    text-decoration: none;
    gap: var(--sp-1);
    transition:
      border-color var(--duration-normal) var(--ease-out),
      box-shadow var(--duration-normal) var(--ease-out),
      transform var(--duration-normal) var(--ease-out);
  }

  .associated__card:hover {
    border-color: var(--color-brass);
    box-shadow: var(--shadow-card-lift);
    transform: translateY(-2px);
  }

  .associated__icon {
    width: 2.5rem;
    height: 2.5rem;
    border-radius: 6px;
    object-fit: cover;
    border: 1px solid var(--color-line);
  }

  .associated__name {
    font-family: var(--font-serif);
    font-size: 1.125rem;
    font-weight: 500;
    color: var(--color-ink);
  }

  .associated__tagline {
    font: var(--text-mono-meta);
    font-family: var(--font-mono);
    color: var(--color-slate);
  }

  .associated__hierarchy-note {
    font: var(--text-mono-meta);
    font-family: var(--font-mono);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--color-brass);
    margin-bottom: var(--sp-3);
    font-size: 0.6875rem;
  }

  .associated__hierarchy-note--secondary {
    color: var(--color-slate);
    margin-top: var(--sp-6);
  }

  .associated__grid--secondary {
    opacity: 0.75;
  }

  .associated__card--secondary {
    padding: var(--sp-4) var(--sp-6);
  }

  @media (max-width: 768px) {
    .associated__grid {
      flex-direction: column;
    }

    .associated__card {
      width: 100%;
    }
  }
</style>
