---
const experiences = [
  {
    period: '2020–Present',
    org: 'Black River Systems Co.',
    location: 'Utica, NY',
    title: 'Senior Machine Learning Software Engineer',
    desc: 'Distributed LLM fine-tuning in TS/SCI SCIF, real-time sonar target recognition on Jetson (sub-50ms), UAV fleet online learning systems, hybrid DSP + ML pipeline architecture.',
  },
  {
    period: '2019–2020',
    org: 'Northeast Information Discovery, Inc.',
    location: 'Canastota, NY',
    title: 'Data Scientist I',
    desc: 'RF modulation classification (+12pp via attention-based spectral encoders), streaming ML deployment across R, Python, and C++.',
  },
  {
    period: '2018–2019',
    org: 'Rochester Institute of Technology',
    location: 'Rochester, NY',
    title: 'Teaching Assistant — Advanced Object-Oriented Programming',
    desc: 'Supported instruction for advanced OOP curriculum while completing M.S. in Computer Science.',
  },
];
---

<section class="timeline">
  <div class="container">
    <h2 class="timeline__heading">Experience</h2>
    <div class="timeline__list">
      {experiences.map((exp) => (
        <article class="timeline__item">
          <span class="timeline__period">{exp.period}</span>
          <div class="timeline__content">
            <h3 class="timeline__title">{exp.title}</h3>
            <p class="timeline__org">{exp.org} — {exp.location}</p>
            <p class="timeline__desc">{exp.desc}</p>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .timeline {
    padding-block: var(--sp-16);
  }

  .timeline__heading {
    font: var(--text-h2);
    font-family: var(--font-serif);
    font-weight: 500;
    margin-bottom: var(--sp-8);
  }

  .timeline__list {
    display: flex;
    flex-direction: column;
    gap: var(--sp-6);
  }

  .timeline__item {
    display: grid;
    grid-template-columns: 8rem 1fr;
    gap: var(--sp-4);
    padding-bottom: var(--sp-6);
    border-bottom: 1px solid var(--color-line);
  }

  .timeline__item:last-child {
    border-bottom: none;
    padding-bottom: 0;
  }

  .timeline__period {
    font: var(--text-mono-meta);
    font-family: var(--font-mono);
    color: var(--color-slate);
    padding-top: 0.15em;
  }

  .timeline__title {
    font: var(--text-h3);
    font-family: var(--font-serif);
    font-weight: 500;
    margin-bottom: var(--sp-1);
    font-size: 1.125rem;
  }

  .timeline__org {
    font: var(--text-meta);
    font-family: var(--font-sans);
    color: var(--color-brass);
    margin-bottom: var(--sp-2);
  }

  .timeline__desc {
    font: var(--text-body);
    font-family: var(--font-sans);
    color: var(--color-slate);
  }

  @media (max-width: 768px) {
    .timeline__item {
      grid-template-columns: 1fr;
      gap: var(--sp-1);
    }
  }
</style>
