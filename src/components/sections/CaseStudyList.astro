---
interface CaseStudy {
  id?: string;
  title: string;
  problem: string;
  narrative: string;
  role: string;
  constraints?: string;
  outcomes?: string;
  note?: string;
}

interface Props {
  items?: CaseStudy[];
}

const { items = [
  {
    id: 'secure-distributed-ml',
    title: 'Secure Distributed ML',
    problem: 'Enable distributed LLM fine-tuning inside a TS/SCI SCIF.',
    narrative: 'Built and owned the full capability covering data pipeline through orchestration, deployment, and operator workflows. Designed for air-gapped, multi-GPU environments with strict compliance and operational security constraints.',
    role: 'Technical lead, architecture, implementation',
    constraints: 'Air-gapped SCIF, classified data handling, multi-GPU coordination',
    outcomes: 'Operational capability delivered; platform adopted for ongoing production use.',
  },
  {
    id: 'real-time-underwater-detection',
    title: 'Real-Time Underwater Detection',
    problem: 'Deliver real-time underwater threat detection with measurable Pd/Pfa.',
    narrative: 'Led ML and engineering for a hybrid DSP + ML pipeline, optimized around detection probability and false-alarm rate at operational latency. Built supporting simulation and synthetic-data workflows for transfer from unclassified training to tactical deployment contexts.',
    role: 'ML lead, pipeline architecture, system integration',
    constraints: 'Sub-50ms latency on Jetson hardware, sonar domain, unclassified-to-classified transfer',
    outcomes: 'Secured multi-year follow-on contract for the U.S. Navy.',
  },
  {
    id: 'adversarial-storage-incentives',
    title: 'Adversarial Storage & Incentives',
    problem: 'Design a ciphertext-only decentralized storage network resilient to adversarial behavior.',
    narrative: 'Designed and led production of a ciphertext-only decentralized storage network built around ongoing interactive proof of spacetime. Validators issue unpredictable, time-local, seed-chained challenges; miners must recompute chunk-level Pedersen commitments bound to the new seed, assemble a Merkle root, and return validator-indexed inclusion proofs. The system validates on encrypted user data, preserving privacy while resisting precomputation and amortized cheating. The network also used a sliding-window incentive and reputation model over reliability, uptime, latency, and correctness.',
    role: 'Protocol design lead, production operations',
    constraints: 'Decentralized and adversarial environment, encrypted user data, anti-precompute / anti-amortization challenge design, incentive alignment over time',
    outcomes: 'Operated at roughly $7M average MRR / ~$60M revenue.',
    note: 'Public-safe summary only; deeper material can be shared selectively.',
  },
  {
    id: 'rf-classification-streaming-ml',
    title: 'RF Classification & Streaming ML',
    problem: 'Improve RF modulation classification accuracy and deploy models into streaming production.',
    narrative: 'Prototyped an RF modulation classifier that improved accuracy by 12 percentage points via attention-based spectral encoders, then deployed models and APIs into streaming production environments across R, Python, and C++.',
    role: 'ML engineer, model development, production deployment',
    constraints: 'Multi-language production stack, streaming latency, spectral domain',
    outcomes: '+12pp accuracy improvement; models deployed to production streaming pipeline.',
  },
  {
    id: 'capability-commons',
    title: 'Capability Commons',
    problem: 'Practical knowledge is trapped inside trades, institutions, guilds, paywalls, jargon, and credential barriers. Most adults cannot maintain the systems their households depend on.',
    narrative: 'Designing an open capability commons that uses AI to convert hidden competence into shared public capacity. The architecture is three interlocking graphs — concept, skill, and deployment — organized by civilizational function rather than academic discipline. Every node is a typed knowledge object (concept, skill, or project) with prerequisites, context-aware facets, and durable output artifacts. The system maps concepts to skills, skills to projects, projects to local deployment, and every learner to teach-forward transmission. The v1 starter graph covers 25 nodes across 7 domains with a concentric-ring entry model from household resilience through community coordination.',
    role: 'Architect, doctrine, knowledge graph design',
    constraints: 'Open by default, layered for beginners, locally adaptable, project-based, teach-forward at every level',
    outcomes: 'V1 graph: 25 nodes, 50 prerequisite edges, 27 navigation edges across 7 capability domains. Doctrine, ontology, and content templates complete.',
    note: 'Active development. The unit of value is the reproducible capability, not the article.',
  },
] } = Astro.props;
---

<section class="case-studies fade-up">
  <div class="container">
    <h2 class="case-studies__heading">Selected Case Studies</h2>
    <div class="case-studies__list">
      {items.map((study) => (
        <article class="case-study" id={study.id}>
          <h3 class="case-study__title">{study.title}</h3>
          <p class="case-study__problem">
            <strong>Problem:</strong> {study.problem}
          </p>
          <p class="case-study__narrative">{study.narrative}</p>
          <dl class="case-study__meta">
            <div class="case-study__meta-item">
              <dt>Role</dt>
              <dd>{study.role}</dd>
            </div>
            {study.constraints && (
              <div class="case-study__meta-item">
                <dt>Constraints</dt>
                <dd>{study.constraints}</dd>
              </div>
            )}
            {study.outcomes && (
              <div class="case-study__meta-item">
                <dt>Outcomes</dt>
                <dd>{study.outcomes}</dd>
              </div>
            )}
          </dl>
          {study.note && <p class="case-study__note">{study.note}</p>}
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .case-studies {
    padding-block: var(--sp-16);
    border-top: 1px solid var(--color-line);
  }

  .case-studies__heading {
    font: var(--text-h2);
    font-family: var(--font-serif);
    font-weight: 500;
    margin-bottom: var(--sp-8);
  }

  .case-studies__list {
    display: flex;
    flex-direction: column;
    gap: var(--sp-12);
  }

  .case-study {
    padding-bottom: var(--sp-12);
    border-bottom: 1px solid var(--color-line);
  }

  .case-study:last-child {
    border-bottom: none;
    padding-bottom: 0;
  }

  .case-study__title {
    font: var(--text-h3);
    font-family: var(--font-serif);
    font-weight: 500;
    margin-bottom: var(--sp-3);
  }

  .case-study__problem {
    font: var(--text-body);
    font-family: var(--font-sans);
    color: var(--color-ink);
    margin-bottom: var(--sp-4);
  }

  .case-study__problem strong {
    color: var(--color-brass);
    font-weight: 500;
  }

  .case-study__narrative {
    font: var(--text-body);
    font-family: var(--font-sans);
    color: var(--color-slate);
    margin-bottom: var(--sp-6);
  }

  .case-study__meta {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(14rem, 1fr));
    gap: var(--sp-4);
    margin-bottom: var(--sp-4);
  }

  .case-study__meta-item dt {
    font: var(--text-mono-meta);
    font-family: var(--font-mono);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--color-slate);
    margin-bottom: var(--sp-1);
  }

  .case-study__meta-item dd {
    font: var(--text-meta);
    font-family: var(--font-sans);
    color: var(--color-ink);
  }

  .case-study__note {
    font: var(--text-meta);
    font-family: var(--font-sans);
    color: var(--color-slate);
    font-style: italic;
    margin-top: var(--sp-4);
  }
</style>
