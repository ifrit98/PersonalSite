---
import Button from '@/components/ui/Button.astro';

import { AFTERFIAT_URL, ESCHATOLOGY_URL, GAMUT_URL } from '@/lib/site';

const features = [
  {
    title: 'AfterFiat',
    body: 'A book-length thesis on verification, repression, synthetic media, and the infrastructure required for credible truth and value in the AI era.',
    href: AFTERFIAT_URL,
    cta: 'Read More',
  },
  {
    title: 'Eschatology Report',
    body: 'Long-form writing on AI acceleration, symbolic overload, civilizational drift, and the search for workable orientation.',
    href: ESCHATOLOGY_URL,
    cta: 'Visit',
  },
  {
    title: 'GAMUT — The Shape of Musical Possibility',
    body: 'A formal mathematical framework that constructs the geometry of twelve-tone pitch space — from cyclic autocorrelation through permutation fibers to symplectic form. Three essays, interactive explorer, and two manuscripts.',
    href: GAMUT_URL,
    cta: 'Explore GAMUT',
    image: '/3d-GAMUT.png',
  },
  {
    title: 'Selected Systems Work',
    body: 'Engineering work across secure environments, distributed ML, real-time detection, and adversarial protocol design.',
    href: '/work',
    cta: 'View Work',
  },
];
---

<section class="features">
  <div class="container">
    <h2 class="features__heading">Selected Domains</h2>
    <div class="features__grid">
      {features.map((f) => (
        <article class:list={['features__card', { 'features__card--has-image': f.image }]}>
          {f.image && (
            <div class="features__image-wrap">
              <img src={f.image} alt="" class="features__image" loading="lazy" />
            </div>
          )}
          <div class="features__content">
            <h3 class="features__title">{f.title}</h3>
            <p class="features__body">{f.body}</p>
            <Button href={f.href} variant="text">{f.cta} &rarr;</Button>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .features {
    padding-block: var(--sp-24);
  }

  .features__heading {
    font: var(--text-h2);
    font-family: var(--font-serif);
    font-weight: 500;
    margin-bottom: var(--sp-12);
  }

  .features__grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--sp-8);
  }

  .features__card {
    padding: var(--sp-8);
    background-color: var(--color-card);
    border: 1px solid var(--color-line);
    border-radius: var(--radius-card);
    transition: box-shadow var(--duration-normal) var(--ease-out);
  }

  .features__card--has-image {
    display: grid;
    grid-template-columns: 5rem 1fr;
    gap: var(--sp-6);
    align-items: start;
  }

  .features__card:hover {
    box-shadow: var(--shadow-card-hover);
  }

  .features__image-wrap {
    width: 5rem;
    height: 5rem;
    border-radius: var(--radius-button);
    overflow: hidden;
    border: 1px solid var(--color-line);
    flex-shrink: 0;
  }

  .features__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .features__title {
    font: var(--text-h3);
    font-family: var(--font-serif);
    font-weight: 500;
    margin-bottom: var(--sp-3);
  }

  .features__body {
    font: var(--text-body);
    font-family: var(--font-sans);
    color: var(--color-slate);
    margin-bottom: var(--sp-4);
  }

  @media (max-width: 768px) {
    .features__grid {
      grid-template-columns: 1fr;
    }
  }
</style>
