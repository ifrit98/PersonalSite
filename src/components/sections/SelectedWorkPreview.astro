---
import Eyebrow from '@/components/ui/Eyebrow.astro';
import Button from '@/components/ui/Button.astro';

const items = [
  {
    title: 'Adversarial Storage & Incentives',
    tag: 'Protocol Design',
    year: '2023–2024',
    desc: 'Ciphertext-only storage network with interactive proof-of-spacetime and tiered incentive model. ~$60M revenue.',
    href: '/work#adversarial-storage-incentives',
  },
  {
    title: 'Real-Time Underwater Detection',
    tag: 'Defense / ML',
    year: '2022–2024',
    desc: 'Hybrid DSP + ML pipeline optimized for Pd/Pfa at sub-50ms latency on edge hardware.',
    href: '/work#real-time-underwater-detection',
  },
  {
    title: 'Secure Distributed ML',
    tag: 'Infrastructure',
    year: '2023–2024',
    desc: 'Distributed LLM fine-tuning capability inside a TS/SCI SCIF environment.',
    href: '/work#secure-distributed-ml',
  },
  {
    title: 'Capability Commons',
    tag: 'Public Initiative / Platform',
    year: 'Ongoing',
    desc: 'Postgres-first knowledge platform: 49 objects, 175 edges, 7 domains. Built on the Agentic Data Lite architecture.',
    href: '/capability-commons',
  },
  {
    title: 'GAMUT — The Shape of Musical Possibility',
    tag: 'Research',
    year: '2025–2026',
    desc: 'Formal geometry of twelve-tone pitch space: essays, proofs, interactive explorer, and two manuscripts.',
    href: '/research#gamut',
  },
  {
    title: 'Music Style Transformer',
    tag: 'Research',
    year: '2020',
    desc: 'Bayesian-factorized approach to raw-audio transcription, composition, and style transfer.',
    href: '/research#music-style-transformer',
  },
];
---

<section class="selected-work fade-up">
  <div class="container">
    <Eyebrow>Selected Work</Eyebrow>
    <h2 class="selected-work__heading">Selected Cases & Research</h2>
    <ul class="selected-work__list" role="list">
      {items.map((item) => (
        <li class="selected-work__item">
          <a href={item.href} class="selected-work__link">
            <div>
              <div class="selected-work__title-row">
                <h3 class="selected-work__title">{item.title}</h3>
                {item.tag && <span class="selected-work__tag">{item.tag}</span>}
                {item.year && <span class="selected-work__year">{item.year}</span>}
              </div>
              <p class="selected-work__desc">{item.desc}</p>
            </div>
            <span class="selected-work__arrow" aria-hidden="true">&rarr;</span>
          </a>
        </li>
      ))}
    </ul>
  </div>
</section>

<style>
  .selected-work {
    padding-block: var(--sp-24);
    border-top: 1px solid var(--color-line);
  }

  .selected-work__heading {
    font: var(--text-h2);
    font-family: var(--font-serif);
    font-weight: 500;
    margin-top: var(--sp-4);
    margin-bottom: var(--sp-8);
  }

  .selected-work__list {
    list-style: none;
  }

  .selected-work__item {
    border-bottom: 1px solid var(--color-line);
  }

  .selected-work__link {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding-block: var(--sp-6);
    text-decoration: none;
    color: var(--color-ink);
    transition: color var(--duration-fast) var(--ease-out);
  }

  .selected-work__link:hover {
    color: var(--color-brass);
  }

  .selected-work__title-row {
    display: flex;
    align-items: baseline;
    gap: var(--sp-3);
    margin-bottom: var(--sp-1);
  }

  .selected-work__title {
    font: var(--text-h3);
    font-family: var(--font-serif);
    font-weight: 500;
  }

  .selected-work__tag {
    font: var(--text-mono-meta);
    font-family: var(--font-mono);
    color: var(--color-brass);
    white-space: nowrap;
    flex-shrink: 0;
  }

  .selected-work__year {
    font: var(--text-mono-meta);
    font-family: var(--font-mono);
    color: var(--color-slate);
    white-space: nowrap;
    flex-shrink: 0;
    opacity: 0.6;
  }

  .selected-work__desc {
    font: var(--text-meta);
    font-family: var(--font-sans);
    color: var(--color-slate);
  }

  .selected-work__arrow {
    font-size: 1.25rem;
    flex-shrink: 0;
    margin-left: var(--sp-4);
    opacity: 0;
    transform: translateX(-4px);
    transition:
      opacity var(--duration-fast) var(--ease-out),
      transform var(--duration-fast) var(--ease-out);
  }

  .selected-work__link:hover .selected-work__arrow {
    opacity: 1;
    transform: translateX(0);
  }
</style>
