---
interface Props {
  class?: string;
}

const { class: className } = Astro.props;
---

<span class:list={['eyebrow', className]}>
  <slot />
</span>

<style>
  .eyebrow {
    font-family: var(--font-mono);
    font: var(--text-mono-meta);
    font-family: var(--font-mono);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-slate);
  }
</style>
