---
import { SITE, NAV_LINKS, UTILITY_LINKS, CONTACT_URL } from '@/lib/site';

const currentPath = Astro.url.pathname;
---

<header class="header" id="site-header">
  <div class="container header__inner">
    <a href="/" class="header__wordmark">{SITE.name}</a>

    <nav class="header__nav" aria-label="Primary navigation">
      <ul class="header__links" role="list">
        {NAV_LINKS.map((link) => (
          <li>
            <a
              href={link.href}
              class:list={['header__link', { 'header__link--active': currentPath.startsWith(link.href) }]}
              aria-current={currentPath.startsWith(link.href) ? 'page' : undefined}
            >
              {link.label}
            </a>
          </li>
        ))}
      </ul>
    </nav>

    <div class="header__utility">
      {UTILITY_LINKS.map((link) => (
        <a href={link.href} class="header__utility-link">{link.label}</a>
      ))}
      <a href={CONTACT_URL} class="header__cta" data-track="nav_primary_cta_click">Discuss an Engagement</a>
    </div>

    <button class="header__mobile-toggle" aria-label="Toggle menu" aria-expanded="false" aria-controls="mobile-menu">
      <span class="header__hamburger"></span>
    </button>
  </div>

  <div class="header__mobile-menu" id="mobile-menu">
    <nav aria-label="Mobile navigation">
      <ul class="header__mobile-links" role="list">
        {NAV_LINKS.map((link) => (
          <li>
            <a
              href={link.href}
              class:list={['header__mobile-link', { 'header__mobile-link--active': currentPath.startsWith(link.href) }]}
            >
              {link.label}
            </a>
          </li>
        ))}
      </ul>
    </nav>
    <div class="header__mobile-utility">
      <a href={CONTACT_URL} class="header__cta" data-track="nav_primary_cta_click">Discuss an Engagement</a>
      {UTILITY_LINKS.map((link) => (
        <a href={link.href} class="header__utility-link">{link.label}</a>
      ))}
    </div>
  </div>
</header>

<style>
  .header {
    position: sticky;
    top: 0;
    z-index: 100;
    background-color: rgba(245, 241, 232, 0.92);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--color-line);
    transition: box-shadow var(--duration-normal) var(--ease-out);
  }

  :global(.header--scrolled) {
    box-shadow: 0 1px 8px rgba(16, 24, 38, 0.06);
  }

  .header__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 4.5rem;
    gap: var(--sp-8);
  }

  .header__wordmark {
    font-family: var(--font-serif);
    font-size: 1.1875rem;
    font-weight: 500;
    color: var(--color-ink);
    text-decoration: none;
    white-space: nowrap;
    letter-spacing: -0.02em;
  }

  .header__wordmark:hover {
    color: var(--color-brass);
  }

  .header__nav {
    flex: 1;
    display: flex;
    justify-content: center;
  }

  .header__links {
    display: flex;
    gap: var(--sp-6);
    list-style: none;
  }

  .header__link {
    font-family: var(--font-sans);
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--color-slate);
    text-decoration: none;
    transition: color var(--duration-fast) var(--ease-out);
  }

  .header__link:hover,
  .header__link--active {
    color: var(--color-ink);
  }

  .header__utility {
    display: flex;
    align-items: center;
    gap: var(--sp-4);
    white-space: nowrap;
  }

  .header__utility-link {
    font-family: var(--font-sans);
    font-size: 0.8125rem;
    color: var(--color-slate);
    text-decoration: none;
  }

  .header__utility-link:hover {
    color: var(--color-brass);
  }

  .header__cta {
    display: inline-flex;
    align-items: center;
    padding: 0.4375rem 1rem;
    font-family: var(--font-sans);
    font-size: 0.8125rem;
    font-weight: 500;
    color: var(--color-bone);
    background-color: var(--color-ink);
    border-radius: var(--radius-button);
    text-decoration: none;
    transition:
      background-color var(--duration-fast) var(--ease-out);
  }

  .header__cta:hover {
    background-color: var(--color-oxblood);
    color: var(--color-bone);
  }

  .header__mobile-toggle {
    display: none;
    background: none;
    border: none;
    cursor: pointer;
    padding: var(--sp-3);
    min-width: 2.75rem;
    min-height: 2.75rem;
    align-items: center;
    justify-content: center;
    -webkit-tap-highlight-color: transparent;
  }

  .header__hamburger,
  .header__hamburger::before,
  .header__hamburger::after {
    display: block;
    width: 1.25rem;
    height: 2px;
    background-color: var(--color-ink);
    transition: transform var(--duration-normal) var(--ease-out),
                opacity var(--duration-fast) var(--ease-out);
    position: relative;
  }

  .header__hamburger::before,
  .header__hamburger::after {
    content: '';
    position: absolute;
    left: 0;
    width: 100%;
  }

  .header__hamburger::before { top: -6px; }
  .header__hamburger::after { top: 6px; }

  .header__mobile-toggle[aria-expanded="true"] .header__hamburger {
    background-color: transparent;
  }

  .header__mobile-toggle[aria-expanded="true"] .header__hamburger::before {
    top: 0;
    transform: rotate(45deg);
  }

  .header__mobile-toggle[aria-expanded="true"] .header__hamburger::after {
    top: 0;
    transform: rotate(-45deg);
  }

  .header__mobile-menu {
    display: none;
  }

  @media (max-width: 960px) {
    .header__nav,
    .header__utility {
      display: none;
    }

    .header__mobile-toggle {
      display: flex;
    }

    .header__mobile-menu {
      display: none;
      flex-direction: column;
      gap: var(--sp-6);
      padding: var(--sp-6) var(--gutter) var(--sp-8);
      border-top: 1px solid var(--color-line);
      background-color: rgba(245, 241, 232, 0.98);
      backdrop-filter: blur(12px);
      -webkit-backdrop-filter: blur(12px);
    }

    .header--open .header__mobile-menu {
      display: flex;
    }

    .header__mobile-links {
      list-style: none;
      display: flex;
      flex-direction: column;
      gap: var(--sp-1);
    }

    .header__mobile-link {
      display: block;
      padding: var(--sp-3) 0;
      font-family: var(--font-sans);
      font-size: 1rem;
      font-weight: 500;
      color: var(--color-slate);
      text-decoration: none;
      border-bottom: 1px solid var(--color-line);
      min-height: 2.75rem;
      transition: color var(--duration-fast) var(--ease-out);
    }

    .header__mobile-link:hover,
    .header__mobile-link--active {
      color: var(--color-ink);
    }

    .header__mobile-utility {
      display: flex;
      flex-direction: column;
      gap: var(--sp-3);
      align-items: flex-start;
    }

    .header__mobile-utility .header__cta {
      padding: 0.625rem 1.25rem;
      font-size: 0.875rem;
    }

    .header__mobile-utility .header__utility-link {
      padding: var(--sp-2) 0;
      min-height: 2.75rem;
      display: flex;
      align-items: center;
    }
  }
</style>

<script>
  const header = document.getElementById('site-header');
  const toggle = document.querySelector('.header__mobile-toggle') as HTMLButtonElement | null;
  const menu = document.getElementById('mobile-menu');

  function openMenu() {
    toggle?.setAttribute('aria-expanded', 'true');
    header?.classList.add('header--open');
    document.body.style.overflow = 'hidden';
    const first = menu?.querySelector<HTMLElement>('a, button');
    first?.focus();
  }

  function closeMenu() {
    toggle?.setAttribute('aria-expanded', 'false');
    header?.classList.remove('header--open');
    document.body.style.overflow = '';
    toggle?.focus();
  }

  function isMenuOpen() {
    return toggle?.getAttribute('aria-expanded') === 'true';
  }

  toggle?.addEventListener('click', () => {
    isMenuOpen() ? closeMenu() : openMenu();
  });

  document.addEventListener('keydown', (e) => {
    if (!isMenuOpen()) return;

    if (e.key === 'Escape') {
      e.preventDefault();
      closeMenu();
      return;
    }

    if (e.key === 'Tab' && menu) {
      const focusable = menu.querySelectorAll<HTMLElement>('a, button');
      if (!focusable.length) return;
      const first = focusable[0];
      const last = focusable[focusable.length - 1];

      if (e.shiftKey && document.activeElement === first) {
        e.preventDefault();
        last.focus();
      } else if (!e.shiftKey && document.activeElement === last) {
        e.preventDefault();
        first.focus();
      }
    }
  });

  let ticking = false;
  window.addEventListener('scroll', () => {
    if (!ticking) {
      requestAnimationFrame(() => {
        header?.classList.toggle('header--scrolled', window.scrollY > 20);
        ticking = false;
      });
      ticking = true;
    }
  }, { passive: true });
</script>
