---
import { SITE, NAV_LINKS } from '@/lib/site';

const currentPath = Astro.url.pathname;
---

<header class="header" id="site-header">
  <div class="container header__inner">
    <a href="/" class="header__wordmark">{SITE.name}</a>

    <nav class="header__nav" aria-label="Primary navigation">
      <ul class="header__links" role="list">
        {NAV_LINKS.map((link) => (
          <li>
            <a
              href={link.href}
              class:list={['header__link', { 'header__link--active': currentPath.startsWith(link.href) }]}
              aria-current={currentPath.startsWith(link.href) ? 'page' : undefined}
            >
              {link.label}
            </a>
          </li>
        ))}
      </ul>
    </nav>

    <div class="header__utility">
      <a href="https://eschatologyreport.substack.com" class="header__utility-link">Eschatology Report</a>
      <a href="https://afterfiat.xyz" class="header__cta">Read AfterFiat</a>
    </div>

    <button class="header__mobile-toggle" aria-label="Toggle menu" aria-expanded="false">
      <span class="header__hamburger"></span>
    </button>
  </div>
</header>

<style>
  .header {
    position: sticky;
    top: 0;
    z-index: 100;
    background-color: rgba(245, 241, 232, 0.92);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--color-line);
  }

  .header__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 4rem;
    gap: var(--sp-8);
  }

  .header__wordmark {
    font-family: var(--font-serif);
    font-size: 1.125rem;
    font-weight: 500;
    color: var(--color-ink);
    text-decoration: none;
    white-space: nowrap;
    letter-spacing: -0.01em;
  }

  .header__wordmark:hover {
    color: var(--color-brass);
  }

  .header__nav {
    flex: 1;
    display: flex;
    justify-content: center;
  }

  .header__links {
    display: flex;
    gap: var(--sp-6);
    list-style: none;
  }

  .header__link {
    font-family: var(--font-sans);
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--color-slate);
    text-decoration: none;
    transition: color var(--duration-fast) var(--ease-out);
  }

  .header__link:hover,
  .header__link--active {
    color: var(--color-ink);
  }

  .header__utility {
    display: flex;
    align-items: center;
    gap: var(--sp-4);
    white-space: nowrap;
  }

  .header__utility-link {
    font-family: var(--font-sans);
    font-size: 0.8125rem;
    color: var(--color-slate);
    text-decoration: none;
  }

  .header__utility-link:hover {
    color: var(--color-brass);
  }

  .header__cta {
    display: inline-flex;
    align-items: center;
    padding: 0.4375rem 1rem;
    font-family: var(--font-sans);
    font-size: 0.8125rem;
    font-weight: 500;
    color: var(--color-bone);
    background-color: var(--color-ink);
    border-radius: var(--radius-button);
    text-decoration: none;
    transition:
      background-color var(--duration-fast) var(--ease-out);
  }

  .header__cta:hover {
    background-color: var(--color-oxblood);
    color: var(--color-bone);
  }

  .header__mobile-toggle {
    display: none;
    background: none;
    border: none;
    cursor: pointer;
    padding: var(--sp-2);
  }

  .header__hamburger,
  .header__hamburger::before,
  .header__hamburger::after {
    display: block;
    width: 1.25rem;
    height: 2px;
    background-color: var(--color-ink);
    transition: transform var(--duration-normal) var(--ease-out);
    position: relative;
  }

  .header__hamburger::before,
  .header__hamburger::after {
    content: '';
    position: absolute;
    left: 0;
    width: 100%;
  }

  .header__hamburger::before { top: -6px; }
  .header__hamburger::after { top: 6px; }

  @media (max-width: 960px) {
    .header__nav,
    .header__utility {
      display: none;
    }

    .header__mobile-toggle {
      display: block;
    }
  }
</style>

<script>
  const toggle = document.querySelector('.header__mobile-toggle');
  const nav = document.querySelector('.header__nav');
  const utility = document.querySelector('.header__utility');

  toggle?.addEventListener('click', () => {
    const expanded = toggle.getAttribute('aria-expanded') === 'true';
    toggle.setAttribute('aria-expanded', String(!expanded));
    nav?.classList.toggle('header__nav--open');
    utility?.classList.toggle('header__utility--open');
  });
</script>
