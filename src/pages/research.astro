---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Button from '@/components/ui/Button.astro';
import { GAMUT_URL } from '@/lib/site';
---

<BaseLayout
  title="Research"
  description="Formal research — including GAMUT, sonification, and music-mathematics — now lives under Projects & Labs."
>
  <section class="redirect fade-up">
    <div class="container container--narrow">
      <h1 class="redirect__title">Research now lives under Projects &amp; Labs</h1>
      <p class="redirect__body">
        Formal research — including GAMUT, sonification, and music-mathematics — has moved to
        <a href="/projects">Projects &amp; Labs</a> alongside the other long-horizon work. This
        reflects a deliberate reorganization: research is part of the same architecture, not a
        separate track.
      </p>

      <a href={GAMUT_URL} class="gamut-card" target="_blank" rel="noopener noreferrer">
        <span class="gamut-card__eyebrow">Research Program / Formal Mathematics</span>
        <span class="gamut-card__name">GAMUT</span>
        <p class="gamut-card__body">
          A formal mathematical framework for the geometry of musical possibility and a research
          surface for structure across sound, symmetry, and form.
        </p>
        <span class="gamut-card__cta">Visit GAMUT →</span>
      </a>

      <div class="redirect__actions">
        <Button href="/projects">Go to Projects &amp; Labs</Button>
        <Button href="/work" variant="secondary">View Work</Button>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .redirect {
    padding-block: var(--sp-24);
    text-align: center;
  }

  .redirect__title {
    font: var(--text-h2);
    font-family: var(--font-serif);
    font-weight: 500;
    color: var(--color-ink);
    margin-bottom: var(--sp-4);
  }

  .redirect__body {
    font: var(--text-body-lg);
    font-family: var(--font-sans);
    color: var(--color-slate);
    margin-bottom: var(--sp-10);
    max-width: 36em;
    margin-inline: auto;
    text-align: left;
  }

  .redirect__body a {
    color: var(--color-brass);
    text-decoration: none;
  }

  .redirect__body a:hover {
    text-decoration: underline;
  }

  .gamut-card {
    display: flex;
    flex-direction: column;
    gap: var(--sp-2);
    max-width: 28rem;
    margin-inline: auto;
    margin-bottom: var(--sp-10);
    padding: var(--sp-6);
    text-align: left;
    text-decoration: none;
    color: inherit;
    border: 1px solid var(--color-line);
    border-left: 3px solid var(--color-brass);
    border-radius: var(--radius-card);
    background-color: var(--color-card-elevated);
    box-shadow: var(--shadow-card-rest);
    transition:
      box-shadow var(--duration-normal) var(--ease-out),
      border-color var(--duration-normal) var(--ease-out);
  }

  .gamut-card:hover {
    border-color: var(--color-brass);
    box-shadow: var(--shadow-card-lift);
  }

  .gamut-card__eyebrow {
    font: var(--text-mono-meta);
    font-family: var(--font-mono);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--color-brass);
    font-size: 0.6875rem;
  }

  .gamut-card__name {
    font-family: var(--font-serif);
    font-size: 1.125rem;
    font-weight: 500;
    color: var(--color-ink);
  }

  .gamut-card__body {
    font: var(--text-body);
    font-family: var(--font-sans);
    color: var(--color-slate);
    margin: var(--sp-1) 0 var(--sp-2);
    max-width: none;
  }

  .gamut-card__cta {
    font: var(--text-meta);
    font-family: var(--font-sans);
    font-weight: 500;
    color: var(--color-brass);
  }

  .gamut-card:hover .gamut-card__cta {
    color: var(--color-oxblood);
  }

  .redirect__actions {
    display: flex;
    gap: var(--sp-4);
    justify-content: center;
    flex-wrap: wrap;
  }
</style>
