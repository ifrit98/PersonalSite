---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Button from '@/components/ui/Button.astro';
import { GAMUT_URL } from '@/lib/site';
---

<BaseLayout
  title="Research"
  description="Research has moved to Projects & Labs. GAMUT and formal research live there now."
>
  <section class="redirect fade-up">
    <div class="container container--narrow">
      <h1 class="redirect__title">Research has moved</h1>
      <p class="redirect__body">
        GAMUT and formal research now live under <a href="/projects">Projects & Labs</a>.
      </p>
      <div class="redirect__actions">
        <Button href="/projects">Go to Projects & Labs</Button>
        <Button href={GAMUT_URL} variant="secondary">Visit GAMUT directly</Button>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .redirect {
    padding-block: var(--sp-24);
    text-align: center;
  }

  .redirect__title {
    font: var(--text-h2);
    font-family: var(--font-serif);
    font-weight: 500;
    color: var(--color-ink);
    margin-bottom: var(--sp-4);
  }

  .redirect__body {
    font: var(--text-body-lg);
    font-family: var(--font-sans);
    color: var(--color-slate);
    margin-bottom: var(--sp-8);
    max-width: 32em;
    margin-inline: auto;
  }

  .redirect__body a {
    color: var(--color-brass);
    text-decoration: none;
  }

  .redirect__body a:hover {
    text-decoration: underline;
  }

  .redirect__actions {
    display: flex;
    gap: var(--sp-4);
    justify-content: center;
    flex-wrap: wrap;
  }
</style>
