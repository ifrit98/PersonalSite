---
import BaseLayout from '@/layouts/BaseLayout.astro';
import PageHero from '@/components/sections/PageHero.astro';
import NarrativeSection from '@/components/sections/NarrativeSection.astro';
import WritingSurfaceGrid from '@/components/sections/WritingSurfaceGrid.astro';
import StartHereList from '@/components/sections/StartHereList.astro';
import CallToActionBand from '@/components/sections/CallToActionBand.astro';
import { AFTERFIAT_URL, ESCHATOLOGY_URL } from '@/lib/site';

const themes = [
  {
    label: 'Verification & Trust',
    desc: 'What happens when soft guarantees fail and cheap verification replaces institutional authority.',
  },
  {
    label: 'Synthetic Media & Epistemic Collapse',
    desc: 'Deepfakes, AI-generated reality, and the structural crisis of knowing what is real.',
  },
  {
    label: 'Money, Repression & Sovereignty',
    desc: 'Post-Bretton Woods monetary drift, financial repression, and the search for neutral stores of value.',
  },
  {
    label: 'Coordination & Civilizational Constraint',
    desc: 'How systems hold together — or fail to — under adversarial conditions and institutional decline.',
  },
  {
    label: 'Existential Orientation',
    desc: 'Agency, dignity, and the problem of modern selfhood when inherited scripts stop working.',
  },
  {
    label: 'Practical Public Capability',
    desc: 'Recovering and transmitting useful knowledge as infrastructure — teach-forward literacy for resilience.',
  },
];

const featured = [
  {
    title: 'Next-Gen Store of Value: Privacy, Proofs, Compute',
    type: 'Thesis',
    surface: 'AfterFiat',
    blurb: 'The core argument: post-Bretton Woods money is compliance-backed, not reserve-backed. When compliance becomes weaponized, savings need privacy the way ships need hulls. Three cryptographic capacities — privacy, proofs, and compute — can function as monetary primitives. The thesis builds a seven-layer cypherpunk stack from verifiable machines up through settlement and governance.',
    href: AFTERFIAT_URL,
  },
  {
    title: 'The Failure of Soft Guarantees',
    type: 'Chapter / Essay',
    surface: 'AfterFiat §1',
    blurb: 'The twentieth century ran on soft guarantees: the promise that money would preserve purchasing power, that televised images would correspond to facts, that institutions would be slow, sober, and legible. The twenty-first runs on different physics. When the symbols of trust are cheaper to counterfeit than to maintain, the market seeks a new substrate.',
    href: `${AFTERFIAT_URL}/v/1.0/read/part-i/1-failure-of-soft-guarantees/`,
  },
  {
    title: 'The World Forces New Monetary Primitives',
    type: 'Chapter / Essay',
    surface: 'AfterFiat §2',
    blurb: 'Total global debt sits at roughly 2.4x world GDP. Historically, such overhangs are closed via financial repression — inflation plus regulation that imposes negative real returns. When repression becomes the spread, capital quietly rotates to neutral, bearer-like rails. Enter the triad: privacy as anti-seizure hull, proofs as cheap public verification, compute as non-coupon revenue base.',
    href: `${AFTERFIAT_URL}/v/1.0/read/part-i/2-world-forces-new-monetary-primitives/`,
  },
  {
    title: 'Why Music Wants a Geometry',
    type: 'Essay / Part I',
    surface: 'GAMUT',
    blurb: 'The opening essay in a three-part mathematical series. The moment one stops asking for the familiar and instead asks for the possible, the floor drops away: 4,096 subsets, 479 million ordered rows, 1.3 billion ordered collections. Cyclic autocorrelation gives the first serious fingerprint of content — and its Fourier shadow plants the seed for everything that follows.',
    href: 'https://musicalgeometry.replit.app/essays/part-i-why-music-wants-a-geometry/',
  },
];
---

<BaseLayout
  title="Writing"
  description="Essays, theses, and long-form work on verification, synthetic media, civilizational constraint, and the search for workable orientation."
>
  <PageHero
    eyebrow="Writing"
    title="Writing"
    body="Essays, theses, and long-form work on verification, synthetic media, civilizational constraint, and the search for workable orientation."
  />

  <NarrativeSection>
    <p>
      The writing extends the same core problem explored in the systems work: what survives when
      institutional legibility fails and synthetic persuasion scales. The throughline is
      straightforward — when trust becomes expensive and synthetic noise becomes cheap, how do we
      maintain signal, coordination, and genuine value?
    </p>
    <p>
      The two primary surfaces are <strong>AfterFiat</strong>, a book-length thesis on the
      infrastructure of credible truth and value in the AI era, and <strong>Eschatology Report</strong>,
      an ongoing publication on philosophy, AI, culture, and civilizational systems. Both are
      summarized below with enough context to evaluate the work before following any outbound link.
    </p>
  </NarrativeSection>

  <WritingSurfaceGrid />

  <section class="themes fade-up">
    <div class="container">
      <h2 class="themes__heading">Thematic Map</h2>
      <p class="themes__intro">
        The writing moves across these interlocking themes. Each appears in both the thesis and the
        ongoing essay work; the separation is organizational, not ideological.
      </p>
      <div class="themes__grid">
        {themes.map((t) => (
          <div class="themes__item">
            <h3 class="themes__label">{t.label}</h3>
            <p class="themes__desc">{t.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="featured fade-up">
    <div class="container">
      <h2 class="featured__heading">Featured Pieces</h2>
      <p class="featured__intro">
        Selected work that represents the range and seriousness of the writing project.
      </p>
      <div class="featured__list">
        {featured.map((f) => (
          <a href={f.href} class="featured__card">
            <div class="featured__card-meta">
              <span class="featured__type">{f.type}</span>
              <span class="featured__surface">{f.surface}</span>
            </div>
            <h3 class="featured__title">{f.title}</h3>
            <p class="featured__blurb">{f.blurb}</p>
          </a>
        ))}
      </div>
    </div>
  </section>

  <StartHereList />

  <CallToActionBand
    heading="Read the work"
    body="Start with AfterFiat for the thesis, then continue into Eschatology Report for the ongoing publication work."
    actions={[
      { label: 'Read AfterFiat', href: AFTERFIAT_URL, variant: 'primary' },
      { label: 'Visit Eschatology Report', href: ESCHATOLOGY_URL, variant: 'secondary' },
      { label: 'Contact Jason', href: '/contact', variant: 'secondary' },
    ]}
  />
</BaseLayout>

<style>
  .themes {
    padding-block: var(--sp-16);
    border-top: 1px solid var(--color-line);
  }

  .themes__heading {
    font: var(--text-h2);
    font-family: var(--font-serif);
    font-weight: 500;
    margin-bottom: var(--sp-2);
  }

  .themes__intro {
    font: var(--text-body);
    font-family: var(--font-sans);
    color: var(--color-slate);
    margin-bottom: var(--sp-8);
    max-width: 42em;
  }

  .themes__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--sp-4);
  }

  .themes__item {
    padding: var(--sp-5) var(--sp-6);
    border-left: 2px solid var(--color-brass);
  }

  .themes__label {
    font: var(--text-body);
    font-family: var(--font-serif);
    font-weight: 500;
    color: var(--color-ink);
    margin-bottom: var(--sp-2);
  }

  .themes__desc {
    font: var(--text-meta);
    font-family: var(--font-sans);
    color: var(--color-slate);
    line-height: 1.6;
  }

  .featured {
    padding-block: var(--sp-16);
    border-top: 1px solid var(--color-line);
  }

  .featured__heading {
    font: var(--text-h2);
    font-family: var(--font-serif);
    font-weight: 500;
    margin-bottom: var(--sp-2);
  }

  .featured__intro {
    font: var(--text-body);
    font-family: var(--font-sans);
    color: var(--color-slate);
    margin-bottom: var(--sp-8);
  }

  .featured__list {
    display: flex;
    flex-direction: column;
    gap: var(--sp-4);
  }

  .featured__card {
    display: block;
    padding: var(--sp-6);
    border: 1px solid rgba(16, 24, 38, 0.08);
    border-radius: var(--radius-card);
    background-color: var(--color-card-elevated);
    box-shadow: var(--shadow-card-rest);
    text-decoration: none;
    transition:
      box-shadow var(--duration-normal) var(--ease-out),
      transform var(--duration-normal) var(--ease-out);
  }

  .featured__card:hover {
    box-shadow: var(--shadow-card-lift);
    transform: translateY(-2px);
  }

  .featured__card-meta {
    display: flex;
    gap: var(--sp-3);
    margin-bottom: var(--sp-2);
  }

  .featured__type {
    font: var(--text-mono-meta);
    font-family: var(--font-mono);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--color-brass);
    font-size: 0.6875rem;
  }

  .featured__surface {
    font: var(--text-mono-meta);
    font-family: var(--font-mono);
    letter-spacing: 0.04em;
    color: var(--color-slate);
    font-size: 0.6875rem;
  }

  .featured__title {
    font: var(--text-h3);
    font-family: var(--font-serif);
    font-weight: 500;
    color: var(--color-ink);
    margin-bottom: var(--sp-3);
    font-size: 1.0625rem;
  }

  .featured__blurb {
    font: var(--text-body);
    font-family: var(--font-sans);
    color: var(--color-slate);
    max-width: 50em;
    line-height: 1.7;
  }

  @media (max-width: 768px) {
    .themes__grid {
      grid-template-columns: 1fr;
    }
  }
</style>
