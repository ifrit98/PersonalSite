---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Button from '@/components/ui/Button.astro';
import {
  AFTERFIAT_URL,
  ESCHATOLOGY_URL,
  GAMUT_URL,
  CAPABILITY_COMMONS_URL,
  ALCHEMICALAI_URL,
} from '@/lib/site';

const coreProperties = [
  {
    name: 'AfterFiat',
    href: AFTERFIAT_URL,
    tagline: 'Thesis / Blueprint',
    body: 'A thesis and blueprint on privacy, proofs, and verified compute as monetary primitives for the next civilizational stack.',
    external: true,
  },
  {
    name: 'Eschatology Report',
    href: ESCHATOLOGY_URL,
    tagline: 'Publication / Essays',
    body: 'An essay publication on AI, culture, institutional drift, existential orientation, and the changing conditions of meaning.',
    external: true,
  },
  {
    name: 'Capability Commons',
    href: CAPABILITY_COMMONS_URL,
    tagline: 'Public Infrastructure / Knowledge Platform',
    body: 'A structured knowledge platform for practical public capability: concepts, skills, projects, assessments, and teach-forward infrastructure.',
    external: false,
  },
  {
    name: 'GAMUT',
    href: GAMUT_URL,
    tagline: 'Research Program / Formal Mathematics',
    body: 'A formal mathematical framework for the geometry of musical possibility and a research surface for structure across sound, symmetry, and form.',
    external: true,
  },
  {
    name: 'AlchemicalAI',
    href: ALCHEMICALAI_URL,
    tagline: 'Applied Systems / Commercial',
    body: 'The commercial and applied surface for selected architecture, infrastructure, and systems work.',
    external: true,
  },
] as const;

const labDirections = [
  {
    title: 'Verified Compute & Proof-Bearing Systems',
    body: 'Systems where computation produces receipts, portable proofs, or economically meaningful verification rather than black-box claims.',
  },
  {
    title: 'Agentic Knowledge Infrastructure',
    body: 'Long-horizon memory, structured knowledge objects, retrieval-aware systems, and interfaces that help people and agents move from information to action.',
  },
  {
    title: 'Public Capability & Local Resilience',
    body: 'Tools and knowledge systems — grounded in real household and community conditions — that help people recover practical competence across infrastructure, maintenance, and everyday dependence.',
  },
  {
    title: 'Music, Geometry & Lawful Form',
    body: 'Research into how structure appears across sound, mathematics, sequence, and machine representation.',
  },
] as const;
---

<BaseLayout
  title="Projects & Labs"
  description="The public properties, research programs, and active builds connecting protocols, writing, knowledge systems, music, and formal structure."
>
  <section class="page-hero fade-up" aria-labelledby="projects-hero-title">
    <div class="container container--narrow">
      <h1 id="projects-hero-title" class="page-hero__title">Projects & Labs</h1>
      <p class="page-hero__body">
        Work shows the systems that shipped under real constraints. Writing makes the thesis explicit.
        Projects & Labs shows the larger architecture: the public properties, research programs, and
        active builds where the ideas compound over time.
      </p>
    </div>
  </section>

  <section class="overview fade-up" aria-labelledby="overview-heading">
    <div class="container container--narrow">
      <h2 id="overview-heading" class="visually-hidden">Overview</h2>
      <p>
        These projects are not a random collection. They are different ways of working on verification,
        capability, coordination, and value in a world where persuasion is cheap and trust is expensive.
        Some are mature public properties. Some are longer-horizon research programs. Some are active
        builds still taking shape.
      </p>
    </div>
  </section>

  <section class="core fade-up" aria-labelledby="core-heading">
    <div class="container">
      <h2 id="core-heading" class="core__heading">Core Properties</h2>
      <p class="core__intro">
        These are the main long-lived properties through which the work becomes publicly legible.
      </p>
      <div class="core__grid" role="list">
        {coreProperties.map((prop) => (
          <a
            href={prop.href}
            class="core__card"
            role="listitem"
            {...(prop.external ? { target: '_blank', rel: 'noopener noreferrer' } : {})}
          >
            <span class="core__tagline">{prop.tagline}</span>
            <span class="core__name">{prop.name}</span>
            <p class="core__body">{prop.body}</p>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="lab fade-up" aria-labelledby="lab-heading">
    <div class="container">
      <h2 id="lab-heading" class="lab__heading">Active Lab Directions</h2>
      <p class="lab__intro">
        Alongside the named properties, several recurring directions function as an active lab rather
        than a finished brand.
      </p>
      <ul class="lab__list" role="list">
        {labDirections.map((item) => (
          <li class="lab__item">
            <span class="lab__title">{item.title}</span>
            <span class="lab__text">{item.body}</span>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <section class="map fade-up" aria-labelledby="map-heading">
    <div class="container container--narrow">
      <h2 id="map-heading" class="map__heading">How the Pieces Fit Together</h2>
      <p class="map__text">
        AfterFiat asks what kind of epistemic and monetary architecture becomes necessary when soft
        guarantees fail. Eschatology Report widens that question into culture, institutions, and
        orientation. Capability Commons turns part of the answer into public infrastructure. GAMUT
        carries the older research thread on form, order, and lawful motion. AlchemicalAI is the
        applied surface where some of these ideas meet clients, systems, and implementation.
      </p>
      <p class="map__text map__text--emphasis">
        Taken together, they form one map rather than several disconnected brands.
      </p>
    </div>
  </section>

  <section class="cta-band fade-up" aria-labelledby="cta-heading">
    <div class="container container--narrow">
      <div class="cta-band__inner">
        <h2 id="cta-heading" class="visually-hidden">Next steps</h2>
        <p class="cta-band__body">
          Start here if you want the larger map. Then move outward into work, writing, or the specific
          property that matches your question.
        </p>
        <div class="cta-band__actions">
          <Button href={CAPABILITY_COMMONS_URL} variant="primary">Explore Capability Commons</Button>
          <Button href={AFTERFIAT_URL} variant="secondary">Read AfterFiat</Button>
          <Button href="/work" variant="secondary">View Work</Button>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .visually-hidden {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  /* PageHero-style bone hero */
  .page-hero {
    padding-block: var(--sp-24) var(--sp-12);
    border-bottom: 1px solid var(--color-line);
  }

  .page-hero__title {
    font: var(--text-h1);
    font-family: var(--font-serif);
    font-weight: 500;
    color: var(--color-ink);
    margin-top: var(--sp-4);
  }

  .page-hero__body {
    font: var(--text-body-lg);
    font-family: var(--font-sans);
    color: var(--color-slate);
    margin-top: var(--sp-4);
    max-width: 38em;
  }

  /* Overview */
  .overview {
    padding-block: var(--sp-16);
  }

  .overview :global(p) {
    font: var(--text-body-lg);
    font-family: var(--font-sans);
    color: var(--color-ink);
    max-width: 42em;
    margin-bottom: 0;
  }

  /* Core Properties grid */
  .core {
    padding-block: var(--sp-16);
    border-top: 1px solid var(--color-line);
  }

  .core__heading {
    font: var(--text-h2);
    font-family: var(--font-serif);
    font-weight: 500;
    margin-bottom: var(--sp-4);
  }

  .core__intro {
    font: var(--text-body);
    font-family: var(--font-sans);
    color: var(--color-slate);
    margin-bottom: var(--sp-8);
    max-width: 38em;
  }

  .core__grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(min(100%, 17.5rem), 1fr));
    gap: var(--sp-6);
    grid-auto-rows: 1fr;
  }

  .core__card {
    display: flex;
    flex-direction: column;
    gap: var(--sp-3);
    padding: var(--sp-6);
    text-decoration: none;
    color: inherit;
    border: 1px solid var(--color-line);
    border-left: 3px solid var(--color-brass);
    border-radius: var(--radius-card);
    background-color: var(--color-card-elevated);
    box-shadow: var(--shadow-card-rest);
    transition:
      border-color var(--duration-normal) var(--ease-out),
      box-shadow var(--duration-normal) var(--ease-out),
      transform var(--duration-normal) var(--ease-out);
  }

  .core__card:hover {
    border-color: var(--color-brass);
    border-left-color: var(--color-brass);
    box-shadow: var(--shadow-card-lift);
    transform: translateY(-2px);
  }

  .core__tagline {
    font: var(--text-mono-meta);
    font-family: var(--font-mono);
    color: var(--color-brass);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    font-size: 0.6875rem;
  }

  .core__name {
    font-family: var(--font-serif);
    font-size: 1.125rem;
    font-weight: 500;
    color: var(--color-ink);
  }

  .core__body {
    font: var(--text-body);
    font-family: var(--font-sans);
    color: var(--color-slate);
    margin: 0;
    max-width: none;
    flex-grow: 1;
  }

  /* Active Lab Directions */
  .lab {
    padding-block: var(--sp-16);
  }

  .lab__heading {
    font: var(--text-h2);
    font-family: var(--font-serif);
    font-weight: 500;
    margin-bottom: var(--sp-4);
  }

  .lab__intro {
    font: var(--text-body);
    font-family: var(--font-sans);
    color: var(--color-slate);
    margin-bottom: var(--sp-6);
    max-width: 38em;
  }

  .lab__list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: var(--sp-4);
  }

  .lab__item {
    display: flex;
    flex-direction: column;
    gap: var(--sp-2);
    padding-left: var(--sp-4);
    border-left: 2px solid var(--color-brass);
  }

  .lab__title {
    font: var(--text-body);
    font-family: var(--font-serif);
    font-weight: 500;
    color: var(--color-ink);
  }

  .lab__text {
    font: var(--text-body);
    font-family: var(--font-sans);
    color: var(--color-slate);
  }

  /* How the pieces fit */
  .map {
    padding-block: var(--sp-16);
    border-top: 1px solid var(--color-line);
  }

  .map__heading {
    font: var(--text-h2);
    font-family: var(--font-serif);
    font-weight: 500;
    margin-bottom: var(--sp-6);
    color: var(--color-ink);
  }

  .map__text {
    font: var(--text-body-lg);
    font-family: var(--font-sans);
    color: var(--color-ink);
    max-width: 42em;
    margin-bottom: var(--sp-6);
  }

  .map__text:last-child {
    margin-bottom: 0;
  }

  .map__text--emphasis {
    color: var(--color-ink);
    font-weight: 500;
  }

  /* CTA */
  .cta-band {
    padding-block: var(--sp-24);
    border-top: 1px solid var(--color-line);
    background-color: var(--color-warm-wash);
  }

  .cta-band__inner {
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .cta-band__body {
    font: var(--text-body);
    font-family: var(--font-sans);
    color: var(--color-slate);
    max-width: 34em;
    text-align: center;
    margin-bottom: var(--sp-8);
  }

  .cta-band__actions {
    display: flex;
    gap: var(--sp-4);
    flex-wrap: wrap;
    justify-content: center;
  }

  @media (max-width: 768px) {
    .page-hero {
      padding-block: var(--sp-16) var(--sp-8);
    }

    .page-hero__title {
      font: var(--text-h2);
      font-family: var(--font-serif);
      font-weight: 500;
    }

    .core__grid {
      grid-template-columns: 1fr;
    }
  }
</style>
