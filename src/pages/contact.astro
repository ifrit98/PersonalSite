---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { SITE } from '@/lib/site';

const inquiryCards = [
  {
    title: 'Architecture & Protocols',
    body: 'System design, protocol analysis, threat modeling, proofs, mechanism design, and verification-heavy technical problems.',
  },
  {
    title: 'ML Infrastructure & Secure Systems',
    body: 'Distributed ML, deployment architecture, air-gapped or high-constraint environments, edge inference, and production workflows.',
  },
  {
    title: 'Research, Writing & Technical Synthesis',
    body: 'Research collaboration, technical memos, publication, long-form synthesis, and translating difficult systems questions into clear language.',
  },
  {
    title: 'Knowledge Platforms & Public Capability',
    body: 'Schema design, capability infrastructure, retrieval systems, curriculum architecture, and teach-forward knowledge products.',
  },
  {
    title: 'Speaking & Interviews',
    body: 'Conversations on verification, AI, money, capability, culture, institutional drift, and related systems questions.',
  },
] as const;
---

<BaseLayout
  title="Contact"
  description="Get in touch for architecture-heavy technical work, research collaborations, writing, publication, speaking, and selective advisory work."
>
  <section class="page-hero fade-up" aria-labelledby="contact-hero-title">
    <div class="container container--narrow">
      <h1 id="contact-hero-title" class="page-hero__title">Contact</h1>
      <p class="page-hero__body">
        For architecture-heavy technical work, research collaborations, writing, publication, speaking, or selective advisory
        conversations.
      </p>
    </div>
  </section>

  <section class="intro fade-up" aria-labelledby="intro-heading">
    <div class="container container--narrow">
      <h2 id="intro-heading" class="sr-only">How to reach out</h2>
      <p class="intro__text">
        The most useful inquiries are clear about the problem, the constraints, and the desired outcome. A short, concrete
        description beats a polished pitch every time.
      </p>
    </div>
  </section>

  <section class="best-fit fade-up" aria-labelledby="best-fit-heading">
    <div class="container">
      <h2 id="best-fit-heading" class="best-fit__heading">Best-Fit Inquiries</h2>
      <p class="best-fit__intro">
        These are the kinds of conversations that tend to be the best fit.
      </p>
      <div class="best-fit__grid">
        {inquiryCards.map((card) => (
          <article class="best-fit__card">
            <h3 class="best-fit__card-title">{card.title}</h3>
            <p class="best-fit__card-body">{card.body}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="direct fade-up" aria-labelledby="direct-heading">
    <div class="container container--narrow">
      <h2 id="direct-heading" class="direct__heading">Direct Contact</h2>
      <p class="direct__body">
        Email is the fastest path. LinkedIn and GitHub are also here for context, prior work, and verification.
      </p>
      <ul class="direct__links" role="list">
        <li>
          <a href={`mailto:${SITE.email}`}>Email Jason</a>
        </li>
        <li>
          <a href={SITE.social.linkedin}>LinkedIn</a>
        </li>
        <li>
          <a href={SITE.social.github}>GitHub</a>
        </li>
      </ul>
    </div>
  </section>
</BaseLayout>

<style>
  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  .page-hero {
    padding-block: var(--sp-24) var(--sp-12);
    border-bottom: 1px solid var(--color-line);
    background-color: var(--color-bone);
  }

  .page-hero__title {
    font: var(--text-h1);
    font-family: var(--font-serif);
    font-weight: 500;
    color: var(--color-ink);
    margin-top: var(--sp-4);
  }

  .page-hero__body {
    font: var(--text-body-lg);
    font-family: var(--font-sans);
    color: var(--color-slate);
    margin-top: var(--sp-4);
    max-width: 38em;
  }

  .intro {
    padding-block: var(--sp-16);
  }

  .intro__text {
    font: var(--text-body-lg);
    font-family: var(--font-sans);
    color: var(--color-ink);
    max-width: 42em;
    margin: 0;
  }

  .best-fit {
    padding-block: var(--sp-16);
    border-top: 1px solid var(--color-line);
  }

  .best-fit__heading {
    font: var(--text-h2);
    font-family: var(--font-serif);
    font-weight: 500;
    margin-bottom: var(--sp-4);
  }

  .best-fit__intro {
    font: var(--text-body);
    font-family: var(--font-sans);
    color: var(--color-slate);
    margin-bottom: var(--sp-8);
    max-width: 38em;
  }

  .best-fit__grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(min(100%, 17.5rem), 1fr));
    gap: var(--sp-6);
    grid-auto-rows: 1fr;
  }

  .best-fit__card {
    display: flex;
    flex-direction: column;
    gap: var(--sp-3);
    padding: var(--sp-6);
    border: 1px solid var(--color-line);
    border-left: 3px solid var(--color-brass);
    border-radius: var(--radius-card);
    background-color: var(--color-card-elevated);
    box-shadow: var(--shadow-card-rest);
    transition:
      border-color var(--duration-normal) var(--ease-out),
      box-shadow var(--duration-normal) var(--ease-out);
  }

  .best-fit__card:hover {
    border-color: var(--color-brass);
    box-shadow: var(--shadow-card-lift);
  }

  .best-fit__card-title {
    font: var(--text-h3);
    font-family: var(--font-serif);
    font-weight: 500;
    font-size: 1.125rem;
    color: var(--color-ink);
    margin: 0;
  }

  .best-fit__card-body {
    font: var(--text-body);
    font-family: var(--font-sans);
    color: var(--color-slate);
    margin: 0;
    max-width: none;
  }

  .direct {
    padding-block: var(--sp-16);
    border-top: 1px solid var(--color-line);
  }

  .direct__heading {
    font: var(--text-h2);
    font-family: var(--font-serif);
    font-weight: 500;
    margin-bottom: var(--sp-4);
  }

  .direct__body {
    font: var(--text-body);
    font-family: var(--font-sans);
    color: var(--color-slate);
    margin-bottom: var(--sp-6);
    max-width: 38em;
  }

  .direct__links {
    list-style: none;
    display: flex;
    gap: var(--sp-6);
    flex-wrap: wrap;
    margin: 0;
    padding: 0;
  }

  .direct__links a {
    font: var(--text-body);
    font-family: var(--font-sans);
    color: var(--color-brass);
    text-decoration: none;
    min-height: 2.75rem;
    display: inline-flex;
    align-items: center;
    transition: color var(--duration-normal) var(--ease-out);
  }

  .direct__links a:hover {
    color: var(--color-oxblood);
  }

  @media (max-width: 768px) {
    .page-hero {
      padding-block: var(--sp-16) var(--sp-8);
    }

    .page-hero__title {
      font: var(--text-h2);
      font-family: var(--font-serif);
      font-weight: 500;
    }

    .best-fit__grid {
      grid-template-columns: 1fr;
    }
  }
</style>
