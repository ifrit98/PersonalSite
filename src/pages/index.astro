---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Button from '@/components/ui/Button.astro';
import {
  SITE,
  AFTERFIAT_URL,
  ESCHATOLOGY_URL,
  ENDORSED_PROPERTIES,
  CONTACT_URL,
} from '@/lib/site';

const proofItems = [
  { text: '7+ years across secure and decentralized systems', href: '/about' },
  { text: '<50ms edge inference on Jetson', href: '/work#real-time-underwater-detection' },
  { text: '128-GPU air-gapped fine-tuning', href: '/work#secure-distributed-ml' },
  { text: '~$60M protocol revenue in production', href: '/work#adversarial-storage-incentives' },
  { text: '~$5M Navy follow-on supported', href: '/work#real-time-underwater-detection' },
  { text: 'Peer-reviewed research + public writing', href: '/writing' },
] as const;

const serviceCards = [
  {
    title: 'Secure ML & High-Constraint Systems',
    body: 'Air-gapped training, deployment architecture, edge inference, and operational ML pipelines.',
  },
  {
    title: 'Protocols, Proofs & Incentives',
    body: 'Threat models, mechanism design, verification-heavy systems, and structures built for strategic environments.',
  },
  {
    title: 'Knowledge, Retrieval & Public Capability',
    body: 'Retrieval systems, context graphs, schemas, and teach-forward platforms that turn information into action.',
  },
  {
    title: 'Technical Synthesis & Fractional Leadership',
    body: 'Architecture review, research memos, briefings, and selective leadership for teams that need a sharper map.',
  },
] as const;

const caseStudies = [
  {
    category: 'Infrastructure / Protocol',
    title: 'Adversarial Storage & Incentives',
    body: 'Ciphertext-only storage network with ongoing proofs, long-horizon incentives, and anti-tamper verification.',
    metric: '~$60M revenue at ~$7M avg MRR',
    href: '/work#adversarial-storage-incentives',
  },
  {
    category: 'Defense / ML',
    title: 'Real-Time Underwater Detection',
    body: 'Hybrid DSP + ML pipeline optimized for operational detection metrics and sub-50ms latency on Jetson hardware.',
    metric: '<50ms inference · ~$5M multi-year follow-on supported',
    href: '/work#real-time-underwater-detection',
  },
  {
    category: 'Defense / Infrastructure',
    title: 'Secure Distributed ML Infrastructure',
    body: 'Distributed LLM fine-tuning and serving inside air-gapped, approval-heavy environments.',
    metric: '128 GPUs operational · 65% cost reduction via quantized adapters',
    href: '/work#secure-distributed-ml',
  },
] as const;

const homePropertyNames = ['AfterFiat', 'Eschatology Report', 'Capability Commons', 'AlchemicalAI', 'SwarmOS'];
const propertyCards = ENDORSED_PROPERTIES
  .filter((p) => homePropertyNames.includes(p.name))
  .map((p) => ({
    name: p.name,
    stage: p.tagline,
    desc: p.description,
    href: p.url,
    external: p.external,
  }));

const finalCards = [
  {
    title: 'Need shipped systems?',
    body: 'See the case studies, operating domains, and selected outcomes.',
    cta: 'View Work',
    href: '/work',
  },
  {
    title: 'Need the larger map?',
    body: 'Explore the projects, labs, and public properties where the ideas compound over time.',
    cta: 'Explore Projects & Labs',
    href: '/projects',
  },
  {
    title: 'Need to talk?',
    body: 'Discuss an engagement, research collaboration, speaking, or selective advisory work.',
    cta: 'Get in Touch',
    href: CONTACT_URL,
  },
] as const;
---

<BaseLayout description={SITE.description}>

  <!-- 1. Hero -->
  <section class="hero fade-up" aria-labelledby="hero-title">
    <div class="container hero__grid">
      <div class="hero__content">
        <span class="hero__eyebrow">Architecture-heavy systems work</span>
        <h1 id="hero-title" class="hero__title">Secure ML, verification, and knowledge systems for real operating constraints.</h1>
        <p class="hero__body">
          I help teams working in high-security, latency-sensitive, adversarial, or high-consequence
          environments design systems that stay credible under pressure — from air-gapped distributed ML
          and real-time edge inference to protocol architecture, agent systems, and retrieval infrastructure.
        </p>
        <p class="hero__thesis">
          The underlying question is simple: what still works when soft guarantees fail?
        </p>
        <div class="hero__actions">
          <Button href={CONTACT_URL} variant="brass" data-track="hero_primary_cta_click">Discuss an Engagement</Button>
          <Button href="#selected-work" variant="ghost" data-track="hero_secondary_cta_click">View Selected Work</Button>
        </div>
        <p class="hero__fit">
          Best fit: secure ML / LLM infrastructure, real-time inference, protocol and mechanism design, agentic retrieval, and fractional technical leadership for high-constraint builds.
        </p>
      </div>
      <div class="hero__visual" aria-hidden="true">
        <svg viewBox="0 0 500 500" xmlns="http://www.w3.org/2000/svg" class="hero__svg">
          <defs>
            <radialGradient id="motif-glow" cx="40%" cy="50%" r="50%">
              <stop offset="0%" stop-color="rgba(169,135,82,0.04)" />
              <stop offset="100%" stop-color="transparent" />
            </radialGradient>
          </defs>
          <circle cx="250" cy="250" r="220" fill="url(#motif-glow)" />
          <g stroke="rgba(169,135,82,0.27)" stroke-width="0.75" fill="none">
            <circle cx="250" cy="250" r="190" />
            <circle cx="250" cy="250" r="140" />
            <circle cx="250" cy="250" r="90" />
            <circle cx="250" cy="250" r="40" opacity="0.5" />
            <line x1="60" y1="250" x2="440" y2="250" />
            <line x1="250" y1="60" x2="250" y2="440" />
            <line x1="115" y1="115" x2="385" y2="385" opacity="0.6" />
            <line x1="385" y1="115" x2="115" y2="385" opacity="0.6" />
            <line x1="250" y1="60" x2="385" y2="115" opacity="0.45" />
            <line x1="385" y1="115" x2="440" y2="250" opacity="0.45" />
            <line x1="440" y1="250" x2="385" y2="385" opacity="0.45" />
            <line x1="385" y1="385" x2="250" y2="440" opacity="0.45" />
            <line x1="250" y1="440" x2="115" y2="385" opacity="0.45" />
            <line x1="115" y1="385" x2="60" y2="250" opacity="0.45" />
            <line x1="60" y1="250" x2="115" y2="115" opacity="0.45" />
            <line x1="115" y1="115" x2="250" y2="60" opacity="0.45" />
            <line x1="250" y1="110" x2="340" y2="160" opacity="0.3" />
            <line x1="340" y1="160" x2="390" y2="250" opacity="0.3" />
            <line x1="390" y1="250" x2="340" y2="340" opacity="0.3" />
            <line x1="340" y1="340" x2="250" y2="390" opacity="0.3" />
            <line x1="250" y1="390" x2="160" y2="340" opacity="0.3" />
            <line x1="160" y1="340" x2="110" y2="250" opacity="0.3" />
            <line x1="110" y1="250" x2="160" y2="160" opacity="0.3" />
            <line x1="160" y1="160" x2="250" y2="110" opacity="0.3" />
          </g>
          <circle cx="250" cy="60" r="4" fill="var(--color-brass)" opacity="0.75" />
          <circle cx="250" cy="440" r="4" fill="var(--color-brass)" opacity="0.75" />
          <circle cx="60" cy="250" r="4" fill="var(--color-brass)" opacity="0.75" />
          <circle cx="440" cy="250" r="4" fill="var(--color-brass)" opacity="0.75" />
          <circle cx="115" cy="115" r="3" fill="var(--color-brass)" opacity="0.5" />
          <circle cx="385" cy="115" r="3" fill="var(--color-brass)" opacity="0.5" />
          <circle cx="115" cy="385" r="3" fill="var(--color-brass)" opacity="0.5" />
          <circle cx="385" cy="385" r="3" fill="var(--color-brass)" opacity="0.5" />
          <circle cx="250" cy="110" r="2.5" fill="var(--color-brass)" opacity="0.4" />
          <circle cx="390" cy="250" r="2.5" fill="var(--color-brass)" opacity="0.4" />
          <circle cx="250" cy="390" r="2.5" fill="var(--color-brass)" opacity="0.4" />
          <circle cx="110" cy="250" r="2.5" fill="var(--color-brass)" opacity="0.4" />
          <circle cx="250" cy="250" r="5" fill="var(--color-brass)" opacity="0.8" />
        </svg>
      </div>
    </div>
  </section>

  <!-- 2. Proof Strip -->
  <section class="proof fade-up" aria-label="Credentials and experience highlights">
    <div class="container">
      <ul class="proof__list">
        {proofItems.map((item, i) => (
          <li class="proof__item fade-up" style={`--stagger: ${i * 60}ms`}>
            <a href={item.href} class="proof__link" data-track="proof_item_click">{item.text}</a>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <!-- 3. Service Cards -->
  <section class="services fade-up" aria-labelledby="services-heading">
    <div class="container">
      <h2 id="services-heading" class="services__heading">What I help teams do</h2>
      <p class="services__intro">
        The best fit is work where the constraints are real and the wrong abstractions are expensive.
      </p>
      <div class="services__grid">
        {serviceCards.map((card, i) => (
          <article class="service-card fade-up" style={`--stagger: ${i * 80}ms`} data-track="service_card_click">
            <h3 class="service-card__title">{card.title}</h3>
            <p class="service-card__body">{card.body}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- 4. Selected Work -->
  <section class="work fade-up" id="selected-work" aria-labelledby="work-heading">
    <div class="container">
      <h2 id="work-heading" class="work__heading">Selected work</h2>
      <p class="work__intro">
        A few examples of the broader thesis expressed in shipped systems, operational constraints, and public infrastructure.
      </p>
      <div class="work__grid">
        {caseStudies.map((cs, i) => (
          <a href={cs.href} class="case-card fade-up" style={`--stagger: ${i * 100}ms`} data-track="case_study_click">
            <span class="case-card__category">{cs.category}</span>
            <h3 class="case-card__title">{cs.title}</h3>
            <p class="case-card__body">{cs.body}</p>
            <span class="case-card__metric">{cs.metric}</span>
            <span class="case-card__cta">Read case study <span aria-hidden="true">→</span></span>
          </a>
        ))}
      </div>
      <div class="work__more">
        <Button href="/work" variant="secondary">View All Work</Button>
      </div>
    </div>
  </section>

  <!-- 5. Engagement CTA Band -->
  <section class="engage fade-up" aria-labelledby="engage-heading">
    <div class="container container--narrow">
      <span class="engage__eyebrow">Work with Jason</span>
      <h2 id="engage-heading" class="engage__title">Bring the problem, the constraints, and the desired outcome.</h2>
      <p class="engage__body">
        I am best suited to architecture-heavy work where clarity matters more than performative velocity:
        protocol and mechanism analysis, secure ML systems, retrieval and knowledge platforms, technical
        synthesis, and selective fractional leadership.
      </p>
      <div class="engage__actions">
        <Button href={CONTACT_URL} variant="brass" data-track="engage_primary_cta_click">Discuss an Engagement</Button>
        <Button href="/work" variant="secondary" data-track="engage_secondary_cta_click">View Work</Button>
      </div>
      <p class="engage__micro">
        Email is the fastest path. A short, concrete description beats a polished pitch.
      </p>
    </div>
  </section>

  <!-- 6. Properties with Stage Tags -->
  <section class="properties fade-up" aria-labelledby="properties-heading">
    <div class="container">
      <h2 id="properties-heading" class="properties__heading">One body of work, several public surfaces</h2>
      <p class="properties__intro">
        These properties are different surfaces of the same broader architecture: verification, capability,
        coordination, and durable value under changing conditions.
      </p>
      <div class="properties__grid">
        {propertyCards.map((prop, i) => (
          <a
            href={prop.href}
            class="prop-card fade-up"
            style={`--stagger: ${i * 80}ms`}
            data-track="property_card_click"
            target={prop.external ? '_blank' : undefined}
            rel={prop.external ? 'noopener noreferrer' : undefined}
          >
            <span class="prop-card__stage">{prop.stage}</span>
            <span class="prop-card__name">{prop.name}</span>
            <p class="prop-card__desc">{prop.desc}</p>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- 7. Writing CTA -->
  <section class="writing-cta fade-up" aria-labelledby="writing-heading">
    <div class="container container--narrow">
      <span class="writing-cta__eyebrow">Writing & Research</span>
      <h2 id="writing-heading" class="writing-cta__title">Follow the larger argument in public.</h2>
      <p class="writing-cta__body">
        The systems work and the writing are part of the same map. Start with AfterFiat for the architecture
        of privacy, proofs, and verified compute. Read Eschatology Report for essays on AI, culture,
        institutions, and orientation.
      </p>
      <div class="writing-cta__actions">
        <Button href="/writing" variant="primary" data-track="writing_cta_click">Read the Writing</Button>
        <Button href={AFTERFIAT_URL} variant="secondary" data-track="writing_cta_afterfiat">Read AfterFiat</Button>
      </div>
      <div class="subscribe-stub" id="subscribe">
        <h3 class="subscribe-stub__title">Get major essays and project releases.</h3>
        <p class="subscribe-stub__body">Low-frequency updates on new writing, public launches, and selected research.</p>
        <form class="subscribe-stub__form" action={ESCHATOLOGY_URL} method="get" target="_blank" rel="noopener noreferrer">
          <Button variant="secondary" data-track="subscribe_click">Subscribe via Substack</Button>
        </form>
      </div>
    </div>
  </section>

  <!-- 8. Final Path Chooser -->
  <section class="paths fade-up" aria-labelledby="paths-heading">
    <div class="container">
      <h2 id="paths-heading" class="paths__heading">Start at the layer that matches your question.</h2>
      <div class="paths__grid">
        {finalCards.map((card, i) => (
          <a href={card.href} class="path-card fade-up" style={`--stagger: ${i * 100}ms`}>
            <h3 class="path-card__title">{card.title}</h3>
            <p class="path-card__body">{card.body}</p>
            <span class="path-card__cta">{card.cta} <span aria-hidden="true">→</span></span>
          </a>
        ))}
      </div>
    </div>
  </section>

</BaseLayout>

<style>
  @keyframes slow-rotate {
    from { transform: rotate(0deg); }
    to { transform: rotate(360deg); }
  }

  /* ===== 1. Hero ===== */
  .hero {
    background-color: var(--color-dark-surface);
    color: var(--color-dark-text);
    padding-block: var(--sp-24) var(--sp-16);
    border-bottom: 1px solid var(--color-dark-line);
    overflow: hidden;
  }

  .hero__grid {
    display: grid;
    grid-template-columns: 1.2fr 0.8fr;
    gap: var(--sp-12);
    align-items: center;
  }

  .hero__eyebrow {
    display: block;
    font: var(--text-mono-meta);
    font-family: var(--font-mono);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-brass);
    margin-bottom: var(--sp-4);
  }

  .hero__title {
    font: var(--text-h1);
    font-family: var(--font-serif);
    font-weight: 500;
    color: var(--color-dark-text);
    letter-spacing: -0.01em;
    max-width: 22ch;
  }

  .hero__body {
    font: var(--text-body-lg);
    font-family: var(--font-sans);
    color: rgba(232, 228, 219, 0.72);
    margin-top: var(--sp-6);
    max-width: 38em;
  }

  .hero__thesis {
    font-size: 1.1875rem;
    line-height: 1.55;
    font-family: var(--font-serif);
    font-style: italic;
    color: var(--color-dark-text);
    margin-top: var(--sp-6);
    max-width: 34em;
  }

  .hero__actions {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: var(--sp-4) var(--sp-6);
    margin-top: var(--sp-8);
  }

  .hero__fit {
    font: var(--text-meta);
    font-family: var(--font-sans);
    color: var(--color-dark-muted);
    margin-top: var(--sp-6);
    max-width: 42em;
  }

  .hero__visual {
    display: flex;
    justify-content: center;
    align-items: center;
    margin-right: -3rem;
  }

  .hero__svg {
    width: 120%;
    max-width: 28rem;
    height: auto;
    animation: slow-rotate 120s linear infinite;
  }

  @media (prefers-reduced-motion: reduce) {
    .hero__svg {
      animation: none;
    }
  }

  /* ===== 2. Proof Strip ===== */
  .proof {
    padding-block: var(--sp-12);
    background-color: var(--color-bone);
    background-image: linear-gradient(180deg, var(--color-warm-wash) 0%, transparent 100%);
    border-bottom: 1px solid var(--color-line);
    position: relative;
  }

  .proof::before {
    content: '';
    position: absolute;
    top: 0;
    left: 50%;
    transform: translateX(-50%);
    width: 3rem;
    height: 2px;
    background-color: var(--color-brass);
  }

  .proof__list {
    list-style: none;
    display: grid;
    gap: var(--sp-4);
    grid-template-columns: repeat(2, 1fr);
  }

  @media (min-width: 1024px) {
    .proof__list {
      grid-template-columns: repeat(6, 1fr);
      gap: var(--sp-6);
    }
  }

  @media (min-width: 640px) and (max-width: 1023px) {
    .proof__list {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  .proof__item {
    font: var(--text-meta);
    font-family: var(--font-sans);
    color: var(--color-slate);
    padding: var(--sp-3) var(--sp-4);
    border-left: 3px solid var(--color-brass);
    transition:
      background-color var(--duration-normal) var(--ease-out),
      border-color var(--duration-normal) var(--ease-out);
  }

  .proof__item:hover {
    background-color: var(--color-warm-wash);
  }

  .proof__link {
    color: inherit;
    text-decoration: none;
    display: block;
  }

  .proof__link:hover {
    color: var(--color-ink);
  }

  /* ===== 3. Service Cards ===== */
  .services {
    padding-block: var(--sp-16);
    background-color: var(--color-bone);
    border-bottom: 1px solid var(--color-line);
  }

  .services__heading {
    font: var(--text-h2);
    font-family: var(--font-serif);
    font-weight: 500;
    color: var(--color-ink);
    margin-bottom: var(--sp-4);
  }

  .services__intro {
    font: var(--text-body);
    font-family: var(--font-sans);
    color: var(--color-slate);
    max-width: 42em;
    margin-bottom: var(--sp-8);
  }

  .services__grid {
    display: grid;
    gap: var(--sp-6);
    grid-template-columns: 1fr;
    grid-auto-rows: 1fr;
  }

  @media (min-width: 640px) {
    .services__grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  .service-card {
    display: flex;
    flex-direction: column;
    padding: var(--sp-6);
    background-color: var(--color-card-elevated);
    border-radius: var(--radius-card);
    border: 1px solid var(--color-line);
    border-left: 3px solid var(--color-brass);
    box-shadow: var(--shadow-card-rest);
    transition:
      border-color var(--duration-normal) var(--ease-out),
      box-shadow var(--duration-normal) var(--ease-out),
      transform var(--duration-normal) var(--ease-out);
  }

  .service-card:hover {
    border-color: var(--color-brass);
    box-shadow: var(--shadow-card-lift);
    transform: translateY(-2px);
  }

  .service-card__title {
    font: var(--text-h3);
    font-family: var(--font-serif);
    font-weight: 500;
    color: var(--color-ink);
    margin-bottom: var(--sp-3);
    font-size: 1.25rem;
  }

  .service-card__body {
    font: var(--text-body);
    font-family: var(--font-sans);
    color: var(--color-slate);
    max-width: none;
  }

  /* ===== 4. Selected Work ===== */
  .work {
    padding-block: var(--sp-16);
    background-color: var(--color-bone);
    border-bottom: 1px solid var(--color-line);
  }

  .work__heading {
    font: var(--text-h2);
    font-family: var(--font-serif);
    font-weight: 500;
    color: var(--color-ink);
    margin-bottom: var(--sp-4);
  }

  .work__intro {
    font: var(--text-body);
    font-family: var(--font-sans);
    color: var(--color-slate);
    max-width: 42em;
    margin-bottom: var(--sp-8);
  }

  .work__grid {
    display: grid;
    gap: var(--sp-6);
    grid-template-columns: 1fr;
  }

  @media (min-width: 768px) {
    .work__grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  .case-card {
    display: flex;
    flex-direction: column;
    gap: var(--sp-3);
    padding: var(--sp-6);
    background-color: var(--color-card-elevated);
    border-radius: var(--radius-card);
    border: 1px solid var(--color-line);
    box-shadow: var(--shadow-card-rest);
    text-decoration: none;
    color: inherit;
    transition:
      border-color var(--duration-normal) var(--ease-out),
      box-shadow var(--duration-normal) var(--ease-out),
      transform var(--duration-normal) var(--ease-out);
  }

  .case-card:hover {
    border-color: var(--color-brass);
    box-shadow: var(--shadow-card-lift);
    transform: translateY(-2px);
  }

  .case-card__category {
    font: var(--text-mono-meta);
    font-family: var(--font-mono);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--color-brass);
  }

  .case-card__title {
    font: var(--text-h3);
    font-family: var(--font-serif);
    font-weight: 500;
    color: var(--color-ink);
    font-size: 1.25rem;
  }

  .case-card__body {
    font: var(--text-body);
    font-family: var(--font-sans);
    color: var(--color-slate);
    max-width: none;
    flex: 1;
  }

  .case-card__metric {
    font: var(--text-meta);
    font-family: var(--font-mono);
    color: var(--color-ink);
    font-weight: 500;
    padding-top: var(--sp-2);
    border-top: 1px solid var(--color-line);
  }

  .case-card__cta {
    font: var(--text-meta);
    font-family: var(--font-sans);
    font-weight: 500;
    color: var(--color-brass);
    transition: color var(--duration-fast) var(--ease-out);
  }

  .case-card:hover .case-card__cta {
    color: var(--color-oxblood);
  }

  .work__more {
    margin-top: var(--sp-8);
  }

  /* ===== 5. Engagement CTA Band ===== */
  .engage {
    background-color: var(--color-dark-surface);
