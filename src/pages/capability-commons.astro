---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Button from '@/components/ui/Button.astro';
import { SITE } from '@/lib/site';

const domains = [
  'Water',
  'Food',
  'Shelter',
  'Power',
  'Repair',
  'Gardening',
  'Systems literacy',
  'Community coordination',
  'Teach-forward practice',
];
---

<BaseLayout
  title="Capability Commons — Open practical knowledge for public capability"
  description="Capability Commons is an open knowledge system for practical literacy: water, food, shelter, power, repair, gardening, systems thinking, and teach-forward public competence."
>
  <section class="cc-hero">
    <div class="container container--narrow">
      <span class="cc-hero__eyebrow">Public Initiative</span>
      <h1 class="cc-hero__title">Capability Commons</h1>
      <p class="cc-hero__lede">
        Open practical knowledge for resilience, systems literacy, and teach-forward public competence.
      </p>
      <p class="cc-hero__body">
        Capability Commons is an open knowledge system that maps concepts to skills, skills to projects,
        and projects to local deployment. Its aim is simple: recover practical knowledge, make it legible,
        and help people teach it forward.
      </p>
      <div class="cc-hero__actions">
        <Button href="#what-it-is" variant="brass">Start Here</Button>
        <Button href="#what-is-live" variant="ghost">Browse the Commons &rarr;</Button>
        <Button href="#contribute" variant="ghost">Developer Docs &rarr;</Button>
      </div>
    </div>
  </section>

  <section class="cc-section fade-up" id="what-it-is">
    <div class="container container--narrow">
      <h2 class="cc-section__heading">What it is</h2>
      <p class="cc-section__body">
        Most people do not need more information. They need clearer paths from understanding to action.
      </p>
      <p class="cc-section__body">
        Capability Commons is built around reproducible capability. Each module is designed to help someone
        understand a principle, perform a task, produce a durable artifact, and explain it clearly to someone else.
      </p>
      <p class="cc-section__body cc-section__body--accent">
        This is not a content feed. It is a public capability system.
      </p>
    </div>
  </section>

  <section class="cc-section cc-section--domains fade-up" id="core-domains">
    <div class="container container--narrow">
      <h2 class="cc-section__heading">Core domains</h2>
      <ul class="cc-domains" role="list">
        {domains.map((domain) => (
          <li class="cc-domains__item">{domain}</li>
        ))}
      </ul>
    </div>
  </section>

  <section class="cc-section fade-up" id="how-it-works">
    <div class="container container--narrow">
      <h2 class="cc-section__heading">How it works</h2>
      <p class="cc-section__body">
        Capability Commons organizes knowledge as a graph:
      </p>
      <ul class="cc-graph-list" role="list">
        <li><strong>concepts</strong> explain what something is</li>
        <li><strong>skills</strong> define what someone can do</li>
        <li><strong>projects</strong> turn understanding into useful artifacts</li>
        <li><strong>modules</strong> sequence the work into learnable paths</li>
        <li><strong>teach-forward packets</strong> help each learner become a transmitter</li>
      </ul>
      <p class="cc-section__body">
        Under the surface, the Commons is powered by a versioned evidence and retrieval layer so guidance
        can be reviewed, updated, localized, and improved over time.
      </p>
    </div>
  </section>

  <section class="cc-section fade-up" id="why-now">
    <div class="container container--narrow">
      <h2 class="cc-section__heading">Why now</h2>
      <p class="cc-section__body">
        Practical competence has become fragmented, gated, outsourced, or trapped behind institutions,
        jargon, and disappearing local memory.
      </p>
      <p class="cc-section__body">
        The point of Capability Commons is not nostalgia. It is public capacity.
      </p>
      <p class="cc-section__body">
        If useful knowledge can be recovered, clarified, and taught forward, more people can become less
        helpless in the face of fragile systems and more useful to one another.
      </p>
    </div>
  </section>

  <section class="cc-section fade-up" id="what-is-live">
    <div class="container container--narrow">
      <h2 class="cc-section__heading">What is live now</h2>
      <p class="cc-section__body">
        The Commons is being built in public. Below is what currently exists and what is in progress.
      </p>

      <div class="cc-modules">
        <h3 class="cc-modules__heading">Starter Modules</h3>
        <div class="cc-modules__grid">
          <div class="cc-modules__card">
            <span class="cc-modules__domain">Water</span>
            <h4 class="cc-modules__title">Household Water Resilience</h4>
            <p class="cc-modules__desc">Storage, filtration, and emergency supply for a household of four. Includes decision tree, equipment list, and maintenance schedule.</p>
            <span class="cc-modules__status cc-modules__status--draft">Template ready</span>
          </div>
          <div class="cc-modules__card">
            <span class="cc-modules__domain">Food</span>
            <h4 class="cc-modules__title">Seed-to-Table Kitchen Garden</h4>
            <p class="cc-modules__desc">First-season garden planning from soil assessment through harvest. Zone-aware planting calendar, companion planting reference, yield tracking worksheet.</p>
            <span class="cc-modules__status cc-modules__status--draft">Template ready</span>
          </div>
          <div class="cc-modules__card">
            <span class="cc-modules__domain">Shelter</span>
            <h4 class="cc-modules__title">Basic Home Weatherization</h4>
            <p class="cc-modules__desc">Air sealing, insulation assessment, and thermal envelope basics. Audit worksheet, material reference, and cost-benefit calculator.</p>
            <span class="cc-modules__status cc-modules__status--planned">In development</span>
          </div>
          <div class="cc-modules__card">
            <span class="cc-modules__domain">Power</span>
            <h4 class="cc-modules__title">Off-Grid Power Fundamentals</h4>
            <p class="cc-modules__desc">Load calculation, battery sizing, solar panel selection. From principles through wiring to a functioning portable system.</p>
            <span class="cc-modules__status cc-modules__status--planned">In development</span>
          </div>
          <div class="cc-modules__card">
            <span class="cc-modules__domain">Systems Literacy</span>
            <h4 class="cc-modules__title">Reading a System</h4>
            <p class="cc-modules__desc">How to identify feedback loops, bottlenecks, failure modes, and leverage points in any system you depend on. Diagramming exercises and real-world case walkthroughs.</p>
            <span class="cc-modules__status cc-modules__status--draft">Template ready</span>
          </div>
          <div class="cc-modules__card">
            <span class="cc-modules__domain">Teach-Forward</span>
            <h4 class="cc-modules__title">Teach-Forward Packet Design</h4>
            <p class="cc-modules__desc">How to take what you have learned, compress it into a teachable unit, and transmit it reliably. Template, checklist, and example packets.</p>
            <span class="cc-modules__status cc-modules__status--draft">Template ready</span>
          </div>
        </div>
      </div>

      <div class="cc-graph-preview">
        <h3 class="cc-modules__heading">Knowledge Graph Architecture</h3>
        <div class="cc-graph-preview__diagram">
          <div class="cc-graph-preview__node cc-graph-preview__node--concept">Concept</div>
          <div class="cc-graph-preview__arrow">&rarr;</div>
          <div class="cc-graph-preview__node cc-graph-preview__node--skill">Skill</div>
          <div class="cc-graph-preview__arrow">&rarr;</div>
          <div class="cc-graph-preview__node cc-graph-preview__node--project">Project</div>
          <div class="cc-graph-preview__arrow">&rarr;</div>
          <div class="cc-graph-preview__node cc-graph-preview__node--module">Module</div>
          <div class="cc-graph-preview__arrow">&rarr;</div>
          <div class="cc-graph-preview__node cc-graph-preview__node--teach">Teach-Forward</div>
        </div>
        <p class="cc-section__body" style="margin-top: var(--sp-4);">
          Each node type is a versioned knowledge object with provenance, evidence links, and revision history.
          The graph connects explanation to action to transmission — every concept has a skill path,
          every skill path produces an artifact, and every module ends with a teach-forward packet.
        </p>
      </div>

      <div class="cc-docs-index">
        <h3 class="cc-modules__heading">Infrastructure & Docs</h3>
        <div class="cc-docs-index__grid">
          <div class="cc-docs-index__item">
            <span class="cc-docs-index__icon">&#9632;</span>
            <div>
              <strong>Module Schema</strong>
              <p>Canonical structure for modules, skills, projects, and teach-forward packets.</p>
            </div>
          </div>
          <div class="cc-docs-index__item">
            <span class="cc-docs-index__icon">&#9632;</span>
            <div>
              <strong>Worksheet Templates</strong>
              <p>Reusable reference sheets, decision trees, audit forms, and planning checklists.</p>
            </div>
          </div>
          <div class="cc-docs-index__item">
            <span class="cc-docs-index__icon">&#9632;</span>
            <div>
              <strong>Graph Specification</strong>
              <p>Schema and API surface for the knowledge object registry and revision layer.</p>
            </div>
          </div>
          <div class="cc-docs-index__item">
            <span class="cc-docs-index__icon">&#9632;</span>
            <div>
              <strong>Governance & Brand</strong>
              <p>Stewarded open-project model, contribution guidelines, and naming conventions.</p>
            </div>
          </div>
        </div>
      </div>

      <div class="cc-roadmap">
        <h3 class="cc-modules__heading">Roadmap & Changelog</h3>
        <div class="cc-roadmap__timeline">
          <div class="cc-roadmap__entry cc-roadmap__entry--done">
            <span class="cc-roadmap__date">2026 Q1</span>
            <div>
              <strong>Foundation</strong>
              <p>Project architecture, module schema, governance model, brand identity, public landing page, starter module templates for Water, Food, Systems Literacy, and Teach-Forward.</p>
            </div>
          </div>
          <div class="cc-roadmap__entry cc-roadmap__entry--current">
            <span class="cc-roadmap__date">2026 Q2</span>
            <div>
              <strong>First Public Artifacts</strong>
              <p>3–5 complete modules with downloadable worksheets, first published learning path, graph API scaffold, developer docs site, initial community contribution workflow.</p>
            </div>
          </div>
          <div class="cc-roadmap__entry">
            <span class="cc-roadmap__date">2026 Q3</span>
            <div>
              <strong>Platform & Graph</strong>
              <p>Knowledge graph explorer, revision and evidence layer integration via Agentic Data Lite, public review workflows, expanded domain coverage (Shelter, Power, Repair).</p>
            </div>
          </div>
          <div class="cc-roadmap__entry">
            <span class="cc-roadmap__date">2026 Q4</span>
            <div>
              <strong>Scale & Community</strong>
              <p>Field report submission, local adaptation framework, community review board, 20+ published modules across all core domains.</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="cc-section fade-up" id="stewardship">
    <div class="container container--narrow">
      <h2 class="cc-section__heading">Stewardship</h2>
      <p class="cc-section__body">
        Capability Commons is founded and stewarded by Jason St George.
      </p>
      <p class="cc-section__body">
        The public initiative sits under a larger body of work on truth, coordination, verification,
        and resilient systems under adversarial conditions. The technical substrate is powered by
        Agentic Data Lite, which supports provenance, revision, evidence retrieval, and long-horizon
        maintenance.
      </p>
    </div>
  </section>

  <section class="cc-section cc-section--contribute fade-up" id="contribute">
    <div class="container container--narrow">
      <h2 class="cc-section__heading">Contribute</h2>
      <p class="cc-section__body">
        There are three ways to contribute:
      </p>
      <ul class="cc-contribute-list" role="list">
        <li>improve the platform</li>
        <li>improve the content</li>
        <li>contribute field reports, local adaptations, and review notes</li>
      </ul>
      <p class="cc-section__body">
        If you want to help build durable public capability, start here.
      </p>
      <div class="cc-section__actions">
        <Button href={SITE.social.github}>View GitHub</Button>
        <Button href="#what-is-live" variant="secondary">Read the Docs</Button>
        <Button href="/contact" variant="secondary">Contact Jason</Button>
      </div>
    </div>
  </section>

  <section class="cc-closing fade-up">
    <div class="container container--narrow">
      <p class="cc-closing__line">Open knowledge is not enough.</p>
      <p class="cc-closing__line cc-closing__line--accent">The goal is usable capability.</p>
    </div>
  </section>
</BaseLayout>

<style>
  /* ── Hero (dark surface) ── */
  .cc-hero {
    background-color: var(--color-dark-surface);
    padding-block: var(--sp-24) var(--sp-16);
  }

  .cc-hero__eyebrow {
    font: var(--text-mono-meta);
    font-family: var(--font-mono);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-brass);
  }

  .cc-hero__title {
    font: var(--text-h1);
    font-family: var(--font-serif);
    font-weight: 500;
    color: var(--color-dark-text);
    margin-top: var(--sp-4);
  }

  .cc-hero__lede {
    font: var(--text-body-lg);
    font-family: var(--font-serif);
    font-style: italic;
    color: var(--color-dark-muted);
    margin-top: var(--sp-4);
    max-width: 38em;
  }

  .cc-hero__body {
    font: var(--text-body-lg);
    font-family: var(--font-sans);
    color: var(--color-dark-muted);
    margin-top: var(--sp-6);
    max-width: 42em;
  }

  .cc-hero__actions {
    display: flex;
    gap: var(--sp-6);
    align-items: center;
    flex-wrap: wrap;
    margin-top: var(--sp-8);
  }

  /* ── Sections ── */
  .cc-section {
    padding-block: var(--sp-16);
    border-bottom: 1px solid var(--color-line);
  }

  .cc-section__heading {
    font: var(--text-h2);
    font-family: var(--font-serif);
    font-weight: 500;
    margin-bottom: var(--sp-6);
  }

  .cc-section__body {
    font: var(--text-body-lg);
    font-family: var(--font-sans);
    color: var(--color-ink);
    max-width: 42em;
    margin-bottom: var(--sp-6);
  }

  .cc-section__body:last-child {
    margin-bottom: 0;
  }

  .cc-section__body--accent {
    font-family: var(--font-serif);
    font-style: italic;
    color: var(--color-brass);
  }

  .cc-section__actions {
    display: flex;
    gap: var(--sp-4);
    flex-wrap: wrap;
    margin-top: var(--sp-8);
  }

  /* ── Core domains ── */
  .cc-domains {
    list-style: none;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--sp-4);
  }

  .cc-domains__item {
    font: var(--text-body);
    font-family: var(--font-sans);
    color: var(--color-ink);
    padding: var(--sp-4) var(--sp-6);
    border: 1px solid rgba(16, 24, 38, 0.08);
    border-radius: var(--radius-card);
    background-color: var(--color-card-elevated);
    box-shadow: var(--shadow-card-rest);
    padding-left: var(--sp-6);
    border-left: 3px solid var(--color-brass);
    transition:
      box-shadow var(--duration-normal) var(--ease-out),
      transform var(--duration-normal) var(--ease-out);
  }

  .cc-domains__item:hover {
    box-shadow: var(--shadow-card-lift);
    transform: translateY(-1px);
  }

  /* ── Graph list (how it works) ── */
  .cc-graph-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: var(--sp-3);
    margin-bottom: var(--sp-6);
  }

  .cc-graph-list li {
    font: var(--text-body);
    font-family: var(--font-sans);
    color: var(--color-ink);
    padding-left: var(--sp-4);
    border-left: 2px solid var(--color-brass);
  }

  .cc-graph-list strong {
    color: var(--color-brass);
    font-weight: 500;
  }

  /* ── Module cards ── */
  .cc-modules {
    margin-bottom: var(--sp-12);
  }

  .cc-modules__heading {
    font: var(--text-mono-meta);
    font-family: var(--font-mono);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--color-brass);
    margin-bottom: var(--sp-4);
  }

  .cc-modules__grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--sp-4);
  }

  .cc-modules__card {
    padding: var(--sp-5) var(--sp-6);
    border: 1px solid rgba(16, 24, 38, 0.08);
    border-radius: var(--radius-card);
    background-color: var(--color-card-elevated);
    box-shadow: var(--shadow-card-rest);
    display: flex;
    flex-direction: column;
    gap: var(--sp-2);
    transition: box-shadow var(--duration-normal) var(--ease-out), transform var(--duration-normal) var(--ease-out);
  }

  .cc-modules__card:hover {
    box-shadow: var(--shadow-card-lift);
    transform: translateY(-1px);
  }

  .cc-modules__domain {
    font: var(--text-mono-meta);
    font-family: var(--font-mono);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--color-brass);
    font-size: 0.6875rem;
  }

  .cc-modules__title {
    font-family: var(--font-serif);
    font-size: 1rem;
    font-weight: 500;
    color: var(--color-ink);
  }

  .cc-modules__desc {
    font: var(--text-meta);
    font-family: var(--font-sans);
    color: var(--color-slate);
    line-height: 1.6;
  }

  .cc-modules__status {
    font: var(--text-mono-meta);
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    letter-spacing: 0.04em;
    margin-top: auto;
    padding-top: var(--sp-2);
  }

  .cc-modules__status--draft {
    color: var(--color-brass);
  }

  .cc-modules__status--planned {
    color: var(--color-slate);
  }

  /* ── Graph preview ── */
  .cc-graph-preview {
    margin-bottom: var(--sp-12);
  }

  .cc-graph-preview__diagram {
    display: flex;
    align-items: center;
    gap: var(--sp-2);
    flex-wrap: wrap;
    padding: var(--sp-6);
    background-color: var(--color-warm-wash);
    border-radius: var(--radius-card);
  }

  .cc-graph-preview__node {
    padding: var(--sp-3) var(--sp-4);
    border-radius: var(--radius-button);
    font-family: var(--font-mono);
    font-size: 0.8125rem;
    font-weight: 500;
    white-space: nowrap;
  }

  .cc-graph-preview__node--concept {
    background-color: rgba(169, 135, 82, 0.15);
    color: var(--color-brass);
    border: 1px solid rgba(169, 135, 82, 0.3);
  }

  .cc-graph-preview__node--skill {
    background-color: rgba(16, 24, 38, 0.06);
    color: var(--color-ink);
    border: 1px solid rgba(16, 24, 38, 0.12);
  }

  .cc-graph-preview__node--project {
    background-color: rgba(16, 24, 38, 0.06);
    color: var(--color-ink);
    border: 1px solid rgba(16, 24, 38, 0.12);
  }

  .cc-graph-preview__node--module {
    background-color: rgba(16, 24, 38, 0.06);
    color: var(--color-ink);
    border: 1px solid rgba(16, 24, 38, 0.12);
  }

  .cc-graph-preview__node--teach {
    background-color: rgba(169, 135, 82, 0.15);
    color: var(--color-brass);
    border: 1px solid rgba(169, 135, 82, 0.3);
  }

  .cc-graph-preview__arrow {
    font-size: 1.25rem;
    color: var(--color-slate);
    opacity: 0.5;
  }

  /* ── Docs index ── */
  .cc-docs-index {
    margin-bottom: var(--sp-12);
  }

  .cc-docs-index__grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--sp-4);
  }

  .cc-docs-index__item {
    display: flex;
    gap: var(--sp-3);
    align-items: flex-start;
    padding: var(--sp-4);
    border: 1px solid rgba(16, 24, 38, 0.06);
    border-radius: var(--radius-card);
    background-color: var(--color-card-elevated);
  }

  .cc-docs-index__icon {
    color: var(--color-brass);
    font-size: 0.625rem;
    margin-top: 0.35em;
    flex-shrink: 0;
  }

  .cc-docs-index__item strong {
    display: block;
    font-family: var(--font-serif);
    font-size: 0.9375rem;
    font-weight: 500;
    color: var(--color-ink);
    margin-bottom: var(--sp-1);
  }

  .cc-docs-index__item p {
    font: var(--text-meta);
    font-family: var(--font-sans);
    color: var(--color-slate);
    line-height: 1.5;
  }

  /* ── Roadmap ── */
  .cc-roadmap {
    margin-bottom: var(--sp-4);
  }

  .cc-roadmap__timeline {
    display: flex;
    flex-direction: column;
    gap: var(--sp-4);
  }

  .cc-roadmap__entry {
    display: grid;
    grid-template-columns: 5rem 1fr;
    gap: var(--sp-4);
    padding: var(--sp-4) var(--sp-6);
    border-left: 2px solid var(--color-line);
  }

  .cc-roadmap__entry--done {
    border-left-color: var(--color-brass);
  }

  .cc-roadmap__entry--current {
    border-left-color: var(--color-brass);
    background-color: var(--color-warm-wash);
    border-radius: 0 var(--radius-card) var(--radius-card) 0;
  }

  .cc-roadmap__date {
    font: var(--text-mono-meta);
    font-family: var(--font-mono);
    color: var(--color-brass);
    white-space: nowrap;
    margin-top: 0.2em;
  }

  .cc-roadmap__entry strong {
    display: block;
    font-family: var(--font-serif);
    font-size: 1rem;
    font-weight: 500;
    color: var(--color-ink);
    margin-bottom: var(--sp-1);
  }

  .cc-roadmap__entry p {
    font: var(--text-meta);
    font-family: var(--font-sans);
    color: var(--color-slate);
    line-height: 1.6;
  }

  /* ── Contribute list ── */
  .cc-contribute-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: var(--sp-3);
    margin-bottom: var(--sp-6);
  }

  .cc-contribute-list li {
    font: var(--text-body);
    font-family: var(--font-sans);
    color: var(--color-ink);
    padding-left: var(--sp-4);
    border-left: 2px solid var(--color-brass);
  }

  /* ── Closing ── */
  .cc-closing {
    padding-block: var(--sp-24);
    text-align: center;
  }

  .cc-closing__line {
    font: var(--text-body-lg);
    font-family: var(--font-serif);
    color: var(--color-slate);
    margin-bottom: var(--sp-2);
  }

  .cc-closing__line--accent {
    font: var(--text-h3);
    font-family: var(--font-serif);
    font-weight: 500;
    color: var(--color-ink);
  }

  /* ── Responsive ── */
  @media (max-width: 768px) {
    .cc-hero {
      padding-block: var(--sp-16) var(--sp-12);
    }

    .cc-hero__title {
