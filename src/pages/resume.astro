---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Button from '@/components/ui/Button.astro';
import {
  AFTERFIAT_URL,
  ESCHATOLOGY_URL,
  CAPABILITY_COMMONS_URL,
  GAMUT_URL,
  ALCHEMICALAI_URL,
  STRUCTURE_LAB_URL,
  SWARMOS_URL,
  AGENTICDATA_URL,
} from '@/lib/site';

const highlights = [
  'Multi-million-dollar protocol operations',
  'Sub-50ms operational inference',
  '7+ years across secure systems',
  'Peer-reviewed research and public writing',
  '8 originated public properties and programs',
] as const;

const programs = [
  {
    name: 'AfterFiat',
    role: 'Author',
    desc: 'Thesis on privacy, proofs, and verified compute as monetary primitives',
    href: AFTERFIAT_URL,
  },
  {
    name: 'Eschatology Report',
    role: 'Author / Editor',
    desc: 'Publication on AI, culture, institutions, and civilizational systems',
    href: ESCHATOLOGY_URL,
  },
  {
    name: 'Capability Commons',
    role: 'Founder / Architect',
    desc: 'Public knowledge platform for practical capability across water, food, shelter, power, repair, and community',
    href: CAPABILITY_COMMONS_URL,
  },
  {
    name: 'GAMUT',
    role: 'Researcher',
    desc: 'Formal research program on the geometry of musical possibility and lawful form',
    href: GAMUT_URL,
  },
  {
    name: 'AlchemicalAI',
    role: 'Founder',
    desc: 'Applied systems and commercial surface for selected architecture and infrastructure work',
    href: ALCHEMICALAI_URL,
  },
  {
    name: 'Structure Lab',
    role: 'Architect / Builder',
    desc: 'Options payoff-engineering platform using MILP optimization for multi-leg structure construction',
    href: STRUCTURE_LAB_URL,
  },
  {
    name: 'SwarmOS',
    role: 'Architect / Builder',
    desc: 'Collective intelligence research platform coordinating specialized AI agents with artifact provenance, claim verification, and reproducibility by default',
    href: SWARMOS_URL,
  },
  {
    name: 'Agentic Data',
    role: 'Architect / Builder',
    desc: 'Enterprise context graph and agentic retrieval planner with causal graph traversal, truth maintenance, and budget-aware evidence assembly',
    href: AGENTICDATA_URL,
  },
] as const;

const experiences = [
  {
    title: 'Senior Machine Learning Software Engineer — Black River Systems Co.',
    location: 'Utica, NY',
    period: 'July 2020 – Present',
    details: [
      'Owned distributed LLM fine-tuning capability end-to-end (data pipeline → training → deployment → operator workflows) in high-security production environment.',
      'Built low-latency edge inference pipeline (<50 ms E2E on Jetson) — transferable to real-time inspection, IoT, and sensor AI applications.',
      'Shipped online learning system for autonomous fleets with bandwidth-aware sync; reduced data egress 60% while maintaining model quality.',
      'Designed scalable agentic system with continuous data ingestion and Blue-Green deployment infrastructure.',
      'Led stakeholder communication and technical briefings; influenced annual AI readiness budget decisions.',
    ],
  },
  {
    title: 'Data Scientist I — Northeast Information Discovery, Inc.',
    location: 'Canastota, NY',
    period: 'June 2019 – May 2020',
    details: [
      'Built RF signal classifier (+12pp accuracy) using attention-based spectral encoders — applicable to any noisy-signal classification task.',
      'Developed production APIs and deployed models into streaming environments (R, Python, C++).',
    ],
  },
  {
    title: 'Teaching Assistant (Advanced OOP) — Rochester Institute of Technology',
    location: 'Rochester, NY',
    period: 'Aug 2018 – Jan 2019',
    details: [
      'Redesigned course recitations around test-driven patterns; improved student project quality 25%.',
    ],
  },
] as const;

const proofPoints = [
  {
    title: 'Decentralized Storage Network',
    body: 'Built and operated a production storage platform from the ground up: anti-tamper verification, reliability/integrity guarantees, incentive system design, and real-time monitoring. Operated to ~$7M avg MRR (~$60M revenue).',
  },
  {
    title: 'U.S. Navy — Real-Time Detection Pipeline',
    body: 'Led ML engineering for a real-time detection pipeline: signal processing + deep learning, optimizing accuracy/false-alarm tradeoffs and latency. Built simulation + synthetic-data workflows for robust training. Helped secure ~$5M multi-year follow-on.',
  },
  {
    title: 'Production LLM Fine-Tuning (128-GPU)',
    body: 'Owned end-to-end: data pipelines, training orchestration, deployment, and operator workflows in regulated environments. Reduced fine-tuning costs 65% via quantized adapters on commodity hardware.',
  },
  {
    title: 'Real-Time Edge Inference',
    body: 'Built DSP → deep learning pipeline achieving <50 ms end-to-end latency on embedded devices. Shipped to production.',
  },
] as const;

const publications = [
  {
    title: 'Music Style Transformer',
    venue: 'ICAI/WorldComp (2019)',
    href: 'https://www.proquest.com/docview/2362906627?pq-origsite=gscholar&fromopenview=true&sourcetype=Conference%20Papers%20&%20Proceedings',
  },
  {
    title: 'Sonification of Simulated Black Hole Merger Data',
    venue: 'MSV (2018)',
    href: 'https://www.proquest.com/docview/2139493498?fromopenview=true&pq-origsite=gscholar&sourcetype=Conference%20Papers%20&%20Proceedings',
  },
] as const;

const education = [
  {
    degree: 'M.S., Computer Science',
    school: 'Rochester Institute of Technology',
    date: 'May 2019',
    focus: 'Deep Learning, Statistical Machine Learning, Advanced ML Topics',
  },
  {
    degree: 'B.M., Performance (Music Theory Minor)',
    school: 'University of North Texas',
    date: 'May 2013',
  },
] as const;

const toolchain = {
  languages: 'Python, Rust, R, Bash, SQL (plus C++/JS/TS familiarity)',
  frameworks: 'PyTorch, TensorFlow, NumPy/SciPy, Pandas, FastAPI, Docker, Kubernetes, Slurm, Git, Linux/Unix, AWS/GCP/Azure',
} as const;
---

<BaseLayout
  title="Resume / CV"
  description="A concise overview of technical leadership, systems work, research, writing, and selected outcomes across secure and decentralized environments."
>
  <section class="page-hero fade-up" aria-labelledby="resume-hero-title">
    <div class="container container--narrow">
      <h1 id="resume-hero-title" class="page-hero__title">Resume / CV</h1>
      <p class="page-hero__body">
        A concise overview of technical leadership, systems work, research, writing, and selected outcomes across secure and
        decentralized environments.
      </p>
    </div>
  </section>

  <section class="summary fade-up" aria-labelledby="summary-heading">
    <div class="container container--narrow">
      <h2 id="summary-heading" class="sr-only">Summary</h2>
      <p class="summary__text">
        I work across protocol design, distributed systems, real-time ML, secure infrastructure, long-form writing, and formal
        research. The public record includes privacy-preserving protocols, distributed ML in high-constraint environments,
        peer-reviewed publications, and public writing on verification, money, and civilizational systems.
      </p>
    </div>
  </section>

  <section class="highlights fade-up" aria-label="Career highlights">
    <div class="container">
      <ul class="highlights__list" role="list">
        {highlights.map((item, i) => (
          <li class="highlights__item fade-up" style={`--stagger: ${i * 80}ms`}>{item}</li>
        ))}
      </ul>
    </div>
  </section>

  <section class="proof-points fade-up" aria-labelledby="proof-heading">
    <div class="container">
      <h2 id="proof-heading" class="section__heading">Proof Points</h2>
      <p class="section__intro">Selected wins with transferable outcomes.</p>
      <div class="proof-points__list">
        {proofPoints.map((pp, i) => (
          <article class="proof-points__item fade-up" style={`--stagger: ${i * 80}ms`}>
            <h3 class="proof-points__title">{pp.title}</h3>
            <p class="proof-points__body">{pp.body}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="programs fade-up" aria-labelledby="programs-heading">
    <div class="container">
      <h2 id="programs-heading" class="section__heading">Independent Programs &amp; Publications</h2>
      <p class="section__intro">
        Originated properties, research programs, and public writing — each built from scratch as part of the same architecture.
      </p>
      <div class="programs__list">
        {programs.map((p, i) => (
          <a
            href={p.href}
            class="programs__entry fade-up"
            style={`--stagger: ${i * 60}ms`}
            {...(p.href.startsWith('/') ? {} : { target: '_blank', rel: 'noopener noreferrer' })}
          >
            <span class="programs__name">{p.name}</span>
            <span class="programs__role">{p.role}</span>
            <span class="programs__desc">{p.desc}</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="experience fade-up" aria-labelledby="experience-heading">
    <div class="container">
      <h2 id="experience-heading" class="section__heading">Work Experience</h2>
      <p class="section__intro">
        Selected roles focused on systems that have to remain reliable under adversarial, operational, or highly constrained conditions.
      </p>
      <div class="experience__timeline">
        {experiences.map((exp) => (
          <article class="experience__entry">
            <span class="experience__period">{exp.period}</span>
            <div class="experience__content">
              <h3 class="experience__title">{exp.title}</h3>
              {exp.location && <span class="experience__location">{exp.location}</span>}
              <ul class="experience__details">
                {exp.details.map((d) => (
                  <li>{d}</li>
                ))}
              </ul>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="education fade-up" aria-labelledby="education-heading">
    <div class="container">
      <h2 id="education-heading" class="section__heading">Education</h2>
      <div class="education__list">
        {education.map((ed) => (
          <article class="education__entry">
            <span class="education__date">{ed.date}</span>
            <div class="education__content">
              <h3 class="education__degree">{ed.degree}</h3>
              <span class="education__school">{ed.school}</span>
              {ed.focus && <span class="education__focus">{ed.focus}</span>}
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="publications fade-up" aria-labelledby="publications-heading">
    <div class="container">
      <h2 id="publications-heading" class="section__heading">Publications</h2>
      <ul class="publications__list" role="list">
        {publications.map((pub) => (
          <li class="publications__item">
            <a href={pub.href} class="publications__link" target="_blank" rel="noopener noreferrer">
              <span class="publications__title">&ldquo;{pub.title}&rdquo;</span>
              <span class="publications__venue"> — {pub.venue}</span>
            </a>
          </li>
        ))}
      </ul>
      <a
        href="https://scholar.google.com/citations?user=vqdQ7YwAAAAJ&hl=en&oi=sra"
        class="publications__scholar"
        target="_blank"
        rel="noopener noreferrer"
      >
        View Google Scholar profile →
      </a>
    </div>
  </section>

  <section class="toolchain fade-up" aria-labelledby="toolchain-heading">
    <div class="container">
      <h2 id="toolchain-heading" class="section__heading">Toolchain</h2>
      <div class="toolchain__grid">
        <div class="toolchain__group">
          <span class="toolchain__label">Languages</span>
          <span class="toolchain__value">{toolchain.languages}</span>
        </div>
        <div class="toolchain__group">
          <span class="toolchain__label">Frameworks & Infra</span>
          <span class="toolchain__value">{toolchain.frameworks}</span>
        </div>
      </div>
    </div>
  </section>

  <section class="cta-band fade-up" aria-labelledby="cta-heading">
    <div class="container">
      <div class="cta-band__inner">
        <h2 id="cta-heading" class="sr-only">Next steps</h2>
        <p class="cta-band__body">
          For the short version, download the résumé. For the fuller picture, use the Work and Projects &amp; Labs pages.
        </p>
        <div class="cta-band__actions">
          <Button href="/papers/resume.pdf" variant="primary">Download Resume</Button>
          <Button href="/contact" variant="secondary">Get in Touch</Button>
          <Button href="/work" variant="secondary">View Work</Button>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  .page-hero {
    padding-block: var(--sp-24) var(--sp-12);
    border-bottom: 1px solid var(--color-line);
    background-color: var(--color-bone);
  }

  .page-hero__title {
    font: var(--text-h1);
    font-family: var(--font-serif);
    font-weight: 500;
    color: var(--color-ink);
    margin-top: var(--sp-4);
  }

  .page-hero__body {
    font: var(--text-body-lg);
    font-family: var(--font-sans);
    color: var(--color-slate);
    margin-top: var(--sp-4);
    max-width: 38em;
  }

  .summary {
    padding-block: var(--sp-16);
  }

  .summary__text {
    font: var(--text-body-lg);
    font-family: var(--font-sans);
    color: var(--color-ink);
    max-width: 42em;
    margin: 0;
  }

  .highlights {
    padding-block: var(--sp-16);
    border-top: 1px solid var(--color-line);
  }

  .highlights__list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: var(--sp-6);
  }

  .highlights__item {
    font: var(--text-body);
    font-family: var(--font-sans);
    color: var(--color-ink);
    padding-left: var(--sp-4);
    border-left: 2px solid var(--color-brass);
    margin: 0;
  }

  .section__heading {
    font: var(--text-h2);
    font-family: var(--font-serif);
    font-weight: 500;
    margin-bottom: var(--sp-4);
  }

  .section__intro {
    font: var(--text-body);
    font-family: var(--font-sans);
    color: var(--color-slate);
    margin-bottom: var(--sp-8);
    max-width: 38em;
  }

  .proof-points {
    padding-block: var(--sp-16);
    border-top: 1px solid var(--color-line);
  }

  .proof-points__list {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--sp-6);
    grid-auto-rows: 1fr;
  }

  .proof-points__item {
    background: var(--color-card-elevated);
    border: 1px solid var(--color-line);
    border-left: 3px solid var(--color-brass);
    border-radius: var(--radius-card);
    box-shadow: var(--shadow-card-rest);
    padding: var(--sp-6);
    display: flex;
    flex-direction: column;
  }

  .proof-points__title {
    font: var(--text-body);
    font-family: var(--font-serif);
    font-weight: 500;
    color: var(--color-ink);
    margin-bottom: var(--sp-3);
  }

  .proof-points__body {
    font: var(--text-body);
    font-family: var(--font-sans);
    color: var(--color-slate);
    margin: 0;
    line-height: 1.6;
  }

  .programs {
    padding-block: var(--sp-16);
    border-top: 1px solid var(--color-line);
  }

  .programs__list {
    display: flex;
    flex-direction: column;
    gap: 0;
    border-top: 1px solid var(--color-line);
  }

  .programs__entry {
    display: grid;
    grid-template-columns: 10rem 9rem 1fr;
    gap: var(--sp-4);
    align-items: baseline;
    padding: var(--sp-4) var(--sp-4) var(--sp-4) var(--sp-5);
    border-bottom: 1px solid var(--color-line);
    border-left: 3px solid var(--color-brass);
    text-decoration: none;
    color: inherit;
    transition: background-color var(--duration-normal) var(--ease-out);
  }

  .programs__entry:hover {
    background-color: var(--color-warm-wash);
  }

  .programs__name {
    font: var(--text-body);
    font-family: var(--font-serif);
    font-weight: 500;
    color: var(--color-ink);
  }

  .programs__role {
    font: var(--text-mono-meta);
    font-family: var(--font-mono);
    color: var(--color-brass);
  }

  .programs__desc {
    font: var(--text-body);
    font-family: var(--font-sans);
    color: var(--color-slate);
  }

  .experience {
    padding-block: var(--sp-16);
  }

  .experience__timeline {
    display: flex;
    flex-direction: column;
    gap: var(--sp-6);
  }

  .experience__entry {
    display: grid;
    grid-template-columns: 11rem 1fr;
    gap: var(--sp-4);
    padding-bottom: var(--sp-6);
    border-bottom: 1px solid var(--color-line);
  }

  .experience__entry:last-child {
    border-bottom: none;
    padding-bottom: 0;
  }

  .experience__period {
    font: var(--text-mono-meta);
    font-family: var(--font-mono);
    color: var(--color-slate);
    padding-top: 0.15em;
    white-space: nowrap;
  }

  .experience__content {
    padding-left: var(--sp-4);
    border-left: 2px solid var(--color-brass);
  }

  .experience__title {
    font: var(--text-body);
    font-family: var(--font-serif);
    font-weight: 500;
    color: var(--color-ink);
    margin: 0 0 var(--sp-1);
  }

  .experience__location {
    display: block;
    font: var(--text-meta);
    font-family: var(--font-sans);
    color: var(--color-slate);
    margin-bottom: var(--sp-3);
  }

  .experience__details {
    font: var(--text-body);
    font-family: var(--font-sans);
    color: var(--color-slate);
    margin: 0;
    padding-left: var(--sp-4);
    display: flex;
    flex-direction: column;
    gap: var(--sp-2);
  }

  .experience__details li {
    line-height: 1.55;
  }

  .education {
    padding-block: var(--sp-16);
    border-top: 1px solid var(--color-line);
  }

  .education__list {
    display: flex;
    flex-direction: column;
    gap: var(--sp-6);
  }

  .education__entry {
    display: grid;
    grid-template-columns: 11rem 1fr;
    gap: var(--sp-4);
  }

  .education__date {
    font: var(--text-mono-meta);
    font-family: var(--font-mono);
    color: var(--color-slate);
    padding-top: 0.15em;
  }

  .education__content {
    padding-left: var(--sp-4);
    border-left: 2px solid var(--color-brass);
  }

  .education__degree {
    font: var(--text-body);
    font-family: var(--font-serif);
    font-weight: 500;
    color: var(--color-ink);
    margin: 0;
  }

  .education__school {
    display: block;
    font: var(--text-body);
    font-family: var(--font-sans);
    color: var(--color-slate);
  }

  .education__focus {
    display: block;
    font: var(--text-meta);
    font-family: var(--font-sans);
    color: var(--color-slate);
    margin-top: var(--sp-1);
  }

  .publications {
    padding-block: var(--sp-16);
    border-top: 1px solid var(--color-line);
  }

  .publications__list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: var(--sp-4);
  }

  .publications__item {
    font: var(--text-body);
    font-family: var(--font-sans);
    color: var(--color-slate);
    margin: 0;
    max-width: 42em;
  }

  .publications__link {
    text-decoration: none;
    color: inherit;
    transition: color var(--duration-normal) var(--ease-out);
  }

  .publications__link:hover .publications__title {
    color: var(--color-brass);
  }

  .publications__title {
    color: var(--color-ink);
    font-weight: 500;
    transition: color var(--duration-normal) var(--ease-out);
  }

  .publications__venue {
    color: var(--color-slate);
  }

  .publications__scholar {
    display: inline-block;
    margin-top: var(--sp-6);
    font: var(--text-meta);
    font-family: var(--font-sans);
    font-weight: 500;
    color: var(--color-brass);
    text-decoration: none;
    transition: color var(--duration-normal) var(--ease-out);
  }

  .publications__scholar:hover {
    color: var(--color-oxblood);
  }

  .toolchain {
    padding-block: var(--sp-16);
    border-top: 1px solid var(--color-line);
  }

  .toolchain__grid {
    display: flex;
    flex-direction: column;
    gap: var(--sp-4);
  }

  .toolchain__group {
    display: flex;
    gap: var(--sp-4);
    align-items: baseline;
  }

  .toolchain__label {
    font: var(--text-mono-meta);
    font-family: var(--font-mono);
    font-weight: 500;
    color: var(--color-brass);
    min-width: 10rem;
    flex-shrink: 0;
  }

  .toolchain__value {
    font: var(--text-body);
    font-family: var(--font-sans);
    color: var(--color-slate);
  }

  .cta-band {
    padding-block: var(--sp-24);
    border-top: 1px solid var(--color-line);
    background-color: var(--color-warm-wash);
  }

  .cta-band__inner {
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .cta-band__body {
    font: var(--text-body);
    font-family: var(--font-sans);
    color: var(--color-slate);
    max-width: 34em;
    text-align: center;
    margin-bottom: var(--sp-8);
  }

  .cta-band__actions {
    display: flex;
    gap: var(--sp-4);
    flex-wrap: wrap;
    justify-content: center;
  }

  @media (max-width: 768px) {
    .page-hero {
      padding-block: var(--sp-16) var(--sp-8);
    }

    .page-hero__title {
      font: var(--text-h2);
      font-family: var(--font-serif);
      font-weight: 500;
    }

    .highlights__list {
      grid-template-columns: 1fr;
    }

    .proof-points__list {
      grid-template-columns: 1fr;
    }

    .programs__entry {
      grid-template-columns: 1fr;
      gap: var(--sp-1);
    }

    .experience__entry,
    .education__entry {
      grid-template-columns: 1fr;
      gap: var(--sp-1);
    }

    .toolchain__group {
      flex-direction: column;
      gap: var(--sp-1);
    }
  }
</style>
