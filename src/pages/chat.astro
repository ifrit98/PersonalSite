---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { SITE } from '@/lib/site';
---

<BaseLayout title="Ask" description={`Ask questions about ${SITE.author}'s work, research, projects, and background.`}>
  <link slot="head" rel="stylesheet" href="https://cdn.jsdelivr.net/npm/katex@0.16.21/dist/katex.min.css" />
  <div class="chat-page">
    <header class="chat-header fade-up">
      <div class="container container--narrow">
        <h1 class="chat-header__title">Ask about my work</h1>
        <p class="chat-header__desc">
          This assistant draws on my published writing, research papers, project
          documentation, and professional background. Ask anything — it will
          cite its sources.
        </p>
      </div>
    </header>

    <div class="chat-container container container--narrow">
      <div class="chat-messages" id="chat-messages" role="log" aria-live="polite" aria-label="Conversation">
        <div class="chat-welcome" id="chat-welcome">
          <p class="chat-welcome__text">A few places to start:</p>
          <div class="chat-starters" id="chat-starters">
            <button class="chat-starter" data-prompt="What is Capability Commons and what problem does it solve?">What is Capability Commons?</button>
            <button class="chat-starter" data-prompt="Tell me about the GAMUT research program and its mathematical framework.">Tell me about GAMUT</button>
            <button class="chat-starter" data-prompt="What is Jason's professional background and what kind of work does he do?">What is Jason's background?</button>
            <button class="chat-starter" data-prompt="What is the AfterFiat thesis about?">What is AfterFiat?</button>
          </div>
        </div>
      </div>

      <form class="chat-input" id="chat-form">
        <label for="chat-input-field" class="sr-only">Your question</label>
        <textarea
          id="chat-input-field"
          class="chat-input__field"
          placeholder="Ask a question..."
          rows="1"
          autocomplete="off"
        ></textarea>
        <button type="submit" class="chat-input__send" id="chat-send" aria-label="Send message">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <line x1="22" y1="2" x2="11" y2="13"></line>
            <polygon points="22 2 15 22 11 13 2 9 22 2"></polygon>
          </svg>
        </button>
      </form>
    </div>
  </div>
</BaseLayout>

<style>
  .chat-page {
    display: flex;
    flex-direction: column;
    min-height: calc(100vh - 4.5rem);
  }

  .chat-header {
    padding: var(--sp-12) 0 var(--sp-8);
    border-bottom: 1px solid var(--color-line);
  }

  .chat-header__title {
    font: var(--text-h2);
    font-family: var(--font-serif);
    font-weight: 500;
    color: var(--color-ink);
    margin-bottom: var(--sp-3);
  }

  .chat-header__desc {
    font: var(--text-body);
    font-family: var(--font-sans);
    color: var(--color-slate);
    max-width: 38em;
  }

  .chat-container {
    flex: 1;
    display: flex;
    flex-direction: column;
    padding-bottom: var(--sp-6);
  }

  .chat-messages {
    flex: 1;
    overflow-y: auto;
    padding: var(--sp-8) 0;
    display: flex;
    flex-direction: column;
    gap: var(--sp-6);
  }

  .chat-welcome {
    display: flex;
    flex-direction: column;
    gap: var(--sp-4);
    padding: var(--sp-8) 0;
  }

  .chat-welcome__text {
    font: var(--text-meta);
    font-family: var(--font-sans);
    color: var(--color-slate);
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }

  .chat-starters {
    display: flex;
    flex-wrap: wrap;
    gap: var(--sp-3);
  }

  .chat-starter {
    font-family: var(--font-sans);
    font-size: 0.875rem;
    color: var(--color-ink);
    background: var(--color-card-elevated);
    border: 1px solid var(--color-line);
    border-radius: var(--radius-button);
    padding: var(--sp-3) var(--sp-5);
    cursor: pointer;
    transition:
      border-color var(--duration-fast) var(--ease-out),
      box-shadow var(--duration-fast) var(--ease-out);
  }

  .chat-starter:hover {
    border-color: var(--color-brass);
    box-shadow: var(--shadow-card-hover);
  }

  .chat-msg {
    display: flex;
    flex-direction: column;
    gap: var(--sp-2);
    max-width: 85%;
    animation: msg-in 300ms var(--ease-entrance) both;
  }

  @keyframes msg-in {
    from {
      opacity: 0;
      transform: translateY(8px);
    }
  }

  .chat-msg--user {
    align-self: flex-end;
  }

  .chat-msg--assistant {
    align-self: flex-start;
  }

  .chat-msg__role {
    font: var(--text-mono-meta);
    font-family: var(--font-mono);
    color: var(--color-slate);
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }

  .chat-msg__bubble {
    padding: var(--sp-4) var(--sp-5);
    border-radius: var(--radius-card);
    line-height: 1.6;
    font-family: var(--font-sans);
    font-size: 0.9375rem;
    word-break: break-word;
  }

  .chat-msg__bubble.is-streaming {
    white-space: pre-wrap;
  }

  .chat-msg--assistant .chat-msg__bubble p {
    margin: 0 0 0.75em;
  }

  .chat-msg--assistant .chat-msg__bubble p:last-child {
    margin-bottom: 0;
  }

  .chat-msg--assistant .chat-msg__bubble ul,
  .chat-msg--assistant .chat-msg__bubble ol {
    margin: 0.5em 0 1em;
    padding-left: 1.5em;
  }

  .chat-msg--assistant .chat-msg__bubble li {
    margin-bottom: 0.4em;
  }

  .chat-msg--assistant .chat-msg__bubble li::marker {
    color: var(--color-slate);
  }

  .chat-msg--assistant .chat-msg__bubble li > ul,
  .chat-msg--assistant .chat-msg__bubble li > ol {
    margin-top: 0.3em;
    margin-bottom: 0.3em;
  }

  .chat-msg--assistant .chat-msg__bubble strong {
    font-weight: 600;
    color: var(--color-ink);
  }

  .chat-msg--assistant .chat-msg__bubble em {
    font-style: italic;
  }

  .chat-msg--assistant .chat-msg__bubble code {
    font-family: var(--font-mono);
    font-size: 0.85em;
    background: rgba(0, 0, 0, 0.05);
    padding: 0.15em 0.35em;
    border-radius: 3px;
  }

  .chat-msg--assistant .chat-msg__bubble pre {
    margin: 0.8em 0;
    padding: var(--sp-3) var(--sp-4);
    background: rgba(0, 0, 0, 0.04);
    border-radius: 6px;
    overflow-x: auto;
    font-size: 0.8125rem;
    line-height: 1.5;
  }

  .chat-msg--assistant .chat-msg__bubble pre code {
    background: none;
    padding: 0;
  }

  .chat-msg--assistant .chat-msg__bubble h3 {
    font-weight: 600;
    margin: 1.2em 0 0.4em;
    font-size: 0.9375rem;
  }

  .chat-msg--assistant .chat-msg__bubble h3:first-child {
    margin-top: 0;
  }

  .chat-msg--assistant .chat-msg__bubble h4 {
    font-weight: 600;
    margin: 1em 0 0.3em;
    font-size: 0.875rem;
    color: var(--color-slate);
  }

  .chat-msg--assistant .chat-msg__bubble blockquote {
    border-left: 2px solid var(--color-brass);
    margin: 0.8em 0;
    padding-left: var(--sp-4);
    color: var(--color-slate);
    font-style: italic;
  }

  .chat-msg--assistant .chat-msg__bubble hr {
    border: none;
    border-top: 1px solid var(--color-line);
    margin: 1em 0;
  }

  .chat-msg--assistant .chat-msg__bubble .katex-block {
    margin: 1em 0;
    overflow-x: auto;
    overflow-y: hidden;
    padding: 8px 0;
    text-align: center;
  }

  .chat-msg--assistant .chat-msg__bubble .katex-display {
    margin: 0;
    overflow-x: auto;
    overflow-y: hidden;
  }

  .chat-msg--assistant .chat-msg__bubble .katex {
    font-size: 1.05em;
  }

  .chat-msg--user .chat-msg__bubble {
    background: var(--color-ink);
    color: var(--color-dark-text);
    border-bottom-right-radius: var(--sp-1);
  }

  .chat-msg--assistant .chat-msg__bubble {
    background: var(--color-card-elevated);
    color: var(--color-ink);
    border: 1px solid var(--color-line);
    border-bottom-left-radius: var(--sp-1);
  }

  .chat-sources {
    display: flex;
    flex-direction: column;
    gap: 6px;
    padding-top: 12px;
    margin-top: 12px;
    border-top: 1px solid var(--color-line);
  }

  .chat-sources__label {
    font-family: var(--font-mono);
    font-size: 0.6rem;
    color: var(--color-slate);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    opacity: 0.6;
    margin-bottom: 2px;
  }

  .chat-sources__list {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }

  .chat-source {
    display: inline-block;
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    line-height: 1.3;
    color: var(--color-slate);
    background: rgba(169, 135, 82, 0.06);
    border: 1px solid rgba(169, 135, 82, 0.15);
    border-radius: 4px;
    padding: 5px 10px;
    text-decoration: none;
    white-space: nowrap;
    max-width: 260px;
    overflow: hidden;
    text-overflow: ellipsis;
    transition:
      border-color var(--duration-fast) var(--ease-out),
      color var(--duration-fast) var(--ease-out),
      background var(--duration-fast) var(--ease-out);
  }

  a.chat-source:hover {
    border-color: var(--color-brass);
    color: var(--color-brass);
    background: rgba(169, 135, 82, 0.1);
  }

  .chat-typing {
    display: flex;
    gap: 4px;
    padding: var(--sp-4) var(--sp-5);
    align-items: center;
  }

  .chat-typing__dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--color-slate);
    opacity: 0.4;
    animation: typing-pulse 1.2s ease-in-out infinite;
  }

  .chat-typing__dot:nth-child(2) { animation-delay: 0.15s; }
  .chat-typing__dot:nth-child(3) { animation-delay: 0.3s; }

  @keyframes typing-pulse {
    0%, 60%, 100% { opacity: 0.4; transform: scale(1); }
    30% { opacity: 1; transform: scale(1.15); }
  }

  .chat-input {
    display: flex;
    align-items: flex-end;
    gap: var(--sp-3);
    padding: var(--sp-4);
    background: var(--color-card-elevated);
    border: 1px solid var(--color-line);
    border-radius: var(--radius-card);
    transition: border-color var(--duration-fast) var(--ease-out);
  }

  .chat-input:focus-within {
    border-color: var(--color-brass);
  }

  .chat-input__field {
    flex: 1;
    border: none;
    background: none;
    font-family: var(--font-sans);
    font-size: 0.9375rem;
    line-height: 1.5;
    color: var(--color-ink);
    resize: none;
    outline: none;
    max-height: 120px;
    overflow-y: auto;
  }

  .chat-input__field::placeholder {
    color: var(--color-slate);
    opacity: 0.6;
  }

  .chat-input__send {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 2.25rem;
    height: 2.25rem;
    border: none;
    border-radius: var(--radius-button);
    background: var(--color-ink);
    color: var(--color-bone);
    cursor: pointer;
    flex-shrink: 0;
    transition:
      background-color var(--duration-fast) var(--ease-out),
      opacity var(--duration-fast) var(--ease-out);
  }

  .chat-input__send:hover {
    background: var(--color-oxblood);
  }

  .chat-input__send:disabled {
    opacity: 0.35;
    cursor: not-allowed;
  }

  @media (prefers-reduced-motion: reduce) {
    .chat-msg { animation: none; }
    .chat-typing__dot { animation: none; opacity: 0.6; }
  }

  @media (max-width: 640px) {
    .chat-header {
      padding: var(--sp-8) 0 var(--sp-6);
    }

    .chat-msg {
      max-width: 92%;
    }

    .chat-starters {
      flex-direction: column;
    }

    .chat-starter {
      text-align: left;
    }
  }
</style>

<script>
  import { marked } from 'marked';
  import katex from 'katex';

  marked.setOptions({
    breaks: true,
    gfm: true,
  });

  function renderLatex(text: string, displayMode: boolean): string {
    try {
      return katex.renderToString(text, { displayMode, throwOnError: false });
    } catch {
      return text;
    }
  }

  function renderMarkdown(raw: string): string {
    try {
      const placeholders: string[] = [];
      const PH_DISPLAY = 'KATEX_DISPLAY_';
      const PH_INLINE = 'KATEX_INLINE_';

      function stashDisplay(tex: string): string {
        const idx = placeholders.length;
        placeholders.push(renderLatex(tex.trim(), true));
        return `\n\n${PH_DISPLAY}${idx}\n\n`;
      }

      function stashInline(tex: string): string {
        const idx = placeholders.length;
        placeholders.push(renderLatex(tex.trim(), false));
        return `${PH_INLINE}${idx}`;
      }

      let processed = raw;

      processed = processed.replace(/\$\$([\s\S]+?)\$\$/g, (_m, t) => stashDisplay(t));
      processed = processed.replace(/\\\[([\s\S]+?)\\\]/g, (_m, t) => stashDisplay(t));

      processed = processed.replace(/\$([^\$\n]+?)\$/g, (_m, t) => stashInline(t));
      processed = processed.replace(/\\\((.+?)\\\)/g, (_m, t) => stashInline(t));

      let html = marked.parse(processed, { async: false }) as string;

      html = html.replace(new RegExp(`${PH_DISPLAY}(\\d+)`, 'g'),
        (_m, idx) => `<div class="katex-block">${placeholders[parseInt(idx, 10)] ?? ''}</div>`);
      html = html.replace(new RegExp(`${PH_INLINE}(\\d+)`, 'g'),
        (_m, idx) => placeholders[parseInt(idx, 10)] ?? '');

      return html;
    } catch (err) {
      console.error('renderMarkdown failed:', err);
      const escaped = raw.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;');
      return `<p>${escaped.replace(/\n/g, '<br>')}</p>`;
    }
  }

  const messagesEl = document.getElementById('chat-messages')!;
  const welcomeEl = document.getElementById('chat-welcome')!;
  const form = document.getElementById('chat-form') as HTMLFormElement;
  const input = document.getElementById('chat-input-field') as HTMLTextAreaElement;
  const sendBtn = document.getElementById('chat-send') as HTMLButtonElement;
  const starterBtns = document.querySelectorAll<HTMLButtonElement>('.chat-starter');

  interface Msg { role: 'user' | 'assistant'; content: string; }
  const history: Msg[] = [];
  let streaming = false;

  function autoResize() {
    input.style.height = 'auto';
    input.style.height = Math.min(input.scrollHeight, 120) + 'px';
  }
  input.addEventListener('input', autoResize);

  input.addEventListener('keydown', (e) => {
    if (e.key === 'Enter' && !e.shiftKey) {
      e.preventDefault();
      form.dispatchEvent(new Event('submit'));
    }
  });

  starterBtns.forEach((btn) => {
    btn.addEventListener('click', () => {
      input.value = btn.dataset.prompt || btn.textContent || '';
      form.dispatchEvent(new Event('submit'));
    });
  });

  function scrollDown() {
    messagesEl.scrollTop = messagesEl.scrollHeight;
  }

  function createMsgEl(role: 'user' | 'assistant', text: string): HTMLElement {
    welcomeEl.style.display = 'none';
    const wrapper = document.createElement('div');
    wrapper.className = 'chat-msg chat-msg--' + role;

    const label = document.createElement('span');
    label.className = 'chat-msg__role';
    label.textContent = role === 'user' ? 'You' : "Jason's AI";

    const bubble = document.createElement('div');
    bubble.className = 'chat-msg__bubble';
    if (role === 'assistant') {
      bubble.classList.add('is-streaming');
    }
    bubble.textContent = text;

    wrapper.appendChild(label);
    wrapper.appendChild(bubble);
    messagesEl.appendChild(wrapper);
    scrollDown();
    return wrapper;
  }

  function createTypingEl(): HTMLElement {
    const wrapper = document.createElement('div');
    wrapper.className = 'chat-msg chat-msg--assistant';

    const label = document.createElement('span');
    label.className = 'chat-msg__role';
    label.textContent = "Jason's AI";

    const bubble = document.createElement('div');
    bubble.className = 'chat-msg__bubble chat-typing';
    for (let i = 0; i < 3; i++) {
      const dot = document.createElement('span');
      dot.className = 'chat-typing__dot';
      bubble.appendChild(dot);
    }

    wrapper.appendChild(label);
    wrapper.appendChild(bubble);
    messagesEl.appendChild(wrapper);
    scrollDown();
    return wrapper;
  }

  function shortenTitle(title: string): string {
    const parts = title.split(' — ');
    if (parts.length === 2) {
      const project = parts[0].trim().split('(')[0].trim();
      let doc = parts[1].trim();
      const projLower = project.toLowerCase();
      if (doc.toLowerCase().startsWith(projLower)) {
        doc = doc.slice(projLower.length).replace(/^[\s:]+/, '').trim();
        if (!doc) return project;
      }
      return doc || project;
    }
    return title
      .replace(/\s*\([^)]+\)\s*/g, ' ')
      .trim();
  }

  function addSourceTags(
    sources: { title: string; url?: string; similarity: number }[],
    wrapper: HTMLElement,
  ) {
    const seen = new Set<string>();
    const unique = sources.filter((s) => {
      if (seen.has(s.title)) return false;
      seen.add(s.title);
      return true;
    });
    if (!unique.length) return;

    const container = document.createElement('div');
    container.className = 'chat-sources';

    const label = document.createElement('span');
    label.className = 'chat-sources__label';
    label.textContent = 'Sources';
    container.appendChild(label);

    const list = document.createElement('div');
    list.className = 'chat-sources__list';

    for (const s of unique.slice(0, 5)) {
      const display = shortenTitle(s.title);
      if (s.url) {
        const a = document.createElement('a');
        a.className = 'chat-source';
        a.href = s.url;
        a.textContent = display;
        if (s.url.startsWith('http')) {
          a.target = '_blank';
          a.rel = 'noopener';
        }
        list.appendChild(a);
      } else {
        const span = document.createElement('span');
        span.className = 'chat-source';
        span.textContent = display;
        list.appendChild(span);
      }
    }
    container.appendChild(list);
    wrapper.querySelector('.chat-msg__bubble')?.after(container);
  }

  async function send(text: string) {
    if (streaming || !text.trim()) return;
    streaming = true;
    sendBtn.disabled = true;

    const trimmed = text.trim();
    history.push({ role: 'user', content: trimmed });
    createMsgEl('user', trimmed);

    const typingEl = createTypingEl();
    let assistantWrapper: HTMLElement | null = null;
    let fullContent = '';

    try {
      const res = await fetch('/api/chat', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ messages: history }),
      });

      if (!res.ok) {
        const errBody = await res.json().catch(() => ({ error: 'Unknown error' }));
        throw new Error(errBody.error || 'HTTP ' + res.status);
      }

      typingEl.remove();
      assistantWrapper = createMsgEl('assistant', '');
      const bubble = assistantWrapper.querySelector('.chat-msg__bubble')!;
      let sources: { title: string; url?: string; similarity: number }[] = [];

      const reader = res.body!.getReader();
      const decoder = new TextDecoder();
      let buffer = '';

      while (true) {
        const { done, value } = await reader.read();
        if (done) break;

        buffer += decoder.decode(value, { stream: true });
        const lines = buffer.split('\n');
        buffer = lines.pop() || '';

        for (const line of lines) {
          if (!line.startsWith('data: ')) continue;
          try {
            const event = JSON.parse(line.slice(6));
            if (event.type === 'sources') {
              sources = event.sources;
            } else if (event.type === 'delta') {
              fullContent += event.content;
              bubble.textContent = fullContent;
              scrollDown();
            }
          } catch { /* skip malformed lines */ }
        }
      }

      bubble.classList.remove('is-streaming');
      let html = renderMarkdown(fullContent);
      html = html.replace(/\(\\([a-zA-Z]+)\)/g, (_m, cmd) => {
        return renderLatex('\\' + cmd, false);
      });
      bubble.innerHTML = html;

      history.push({ role: 'assistant', content: fullContent });
      if (assistantWrapper) addSourceTags(sources, assistantWrapper);
    } catch (err) {
      typingEl.remove();
      const detail = err instanceof Error ? err.message : String(err);
      if (!assistantWrapper) {
        createMsgEl('assistant', 'Sorry, something went wrong: ' + detail);
      }
      console.error('Chat error:', detail);
    } finally {
      streaming = false;
      sendBtn.disabled = false;
      scrollDown();
    }
  }

  form.addEventListener('submit', (e) => {
    e.preventDefault();
    const text = input.value;
    input.value = '';
    autoResize();
    send(text);
  });
</script>
